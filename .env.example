# Strikingly Project Configuration (for form submissions / database)
# Copy this file to .env.local and fill in your actual values for local development.
# In production builds, set these as VITE_* environment variables.

VITE_STRK_PROJECT_URL=https://www.uat.strikingly.com/api/v1/sites/YOUR_SITE_ID/form_entities
VITE_STRK_PROJECT_ANON_KEY=your_anon_key_here
VITE_SITE_ID=YOUR_SITE_ID
VITE_REQUEST_DOMAIN=https://www.uat.strikingly.com
VITE_S3_DOMAIN=https://strikingly-user-asset-images-dev.s3.ap-northeast-1.amazonaws.com

# Optional: Unsplash (for any image features if used)
# UNSPLASH_ACCESS_KEY=your_unsplash_key_here
