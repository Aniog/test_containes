{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trip Days",
  "type": "object",
  "properties": {
    "trip_id": {
      "type": "integer",
      "description": "Reference to the parent trip",
      "x-foreignKey": "trips.id"
    },
    "label": {
      "type": "string",
      "maxLength": 200,
      "description": "Label or title for this day (e.g. Arrival Day)"
    },
    "day_order": {
      "type": "integer",
      "minimum": 1,
      "description": "Position of this day within the trip"
    }
  },
  "required": ["trip_id", "day_order"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
