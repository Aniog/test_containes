{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "User Accounts",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "User email address, used as unique login identifier"
    },
    "password_hash": {
      "type": "string",
      "minLength": 1,
      "description": "SHA-256 hash of the user password"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Display name of the user"
    },
    "role": {
      "type": "string",
      "enum": ["user", "admin"],
      "default": "user",
      "description": "User role: user or admin"
    }
  },
  "required": ["email", "password_hash", "name", "role"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
