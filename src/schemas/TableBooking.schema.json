{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Table Bookings",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person making the reservation"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for booking confirmation"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number for the reservation"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the reservation"
    },
    "time": {
      "type": "string",
      "enum": ["12:00", "12:30", "13:00", "13:30", "14:00", "18:00", "18:30", "19:00", "19:30", "20:00", "20:30", "21:00"],
      "description": "Time slot for the reservation"
    },
    "party_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "description": "Number of guests in the party"
    },
    "special_requests": {
      "type": "string",
      "maxLength": 500,
      "description": "Any special requests or dietary requirements"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "cancelled"],
      "default": "pending",
      "description": "Status of the booking"
    }
  },
  "required": ["name", "email", "date", "time", "party_size"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
