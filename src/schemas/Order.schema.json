{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orders",
  "type": "object",
  "properties": {
    "customer_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the customer"
    },
    "customer_email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the customer"
    },
    "customer_phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the customer"
    },
    "delivery_address": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Delivery address for the order"
    },
    "items": {
      "type": "array",
      "description": "List of items in the order",
      "items": {
        "type": "object",
        "properties": {
          "fruit_id": { "type": "integer", "description": "ID of the fruit product" },
          "name": { "type": "string", "description": "Name of the fruit" },
          "emoji": { "type": "string", "description": "Emoji for the fruit" },
          "price": { "type": "number", "description": "Unit price" },
          "unit": { "type": "string", "description": "Unit label e.g. 250g" },
          "quantity": { "type": "integer", "minimum": 1, "description": "Quantity ordered" }
        }
      }
    },
    "total_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Total order amount in USD"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "confirmed", "delivered", "cancelled"],
      "default": "pending",
      "description": "Current status of the order"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional delivery notes from the customer"
    }
  },
  "required": ["customer_name", "customer_email", "delivery_address", "items", "total_amount", "status"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
