{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orders",
  "type": "object",
  "properties": {
    "customer_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Customer full name"
    },
    "phone": {
      "type": "string",
      "maxLength": 20,
      "description": "Customer phone number"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Customer email address"
    },
    "province": {
      "type": "string",
      "maxLength": 50,
      "description": "Shipping province"
    },
    "city": {
      "type": "string",
      "maxLength": 50,
      "description": "Shipping city"
    },
    "address": {
      "type": "string",
      "maxLength": 300,
      "description": "Detailed shipping address"
    },
    "postal_code": {
      "type": "string",
      "maxLength": 10,
      "description": "Postal code"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": { "type": "integer" },
          "product_name": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "image_url": { "type": "string" }
        }
      },
      "description": "List of ordered items with product details snapshot"
    },
    "subtotal": {
      "type": "number",
      "minimum": 0,
      "description": "Order subtotal before shipping in CNY"
    },
    "shipping_fee": {
      "type": "number",
      "minimum": 0,
      "description": "Shipping fee in CNY"
    },
    "total_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Total order amount including shipping in CNY"
    },
    "payment_method": {
      "type": "string",
      "enum": ["alipay", "wechat_pay", "unionpay", "cod"],
      "description": "Payment method selected by customer"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "paid", "processing", "shipped", "delivered", "cancelled"],
      "default": "pending",
      "description": "Current order status"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Customer order notes"
    },
    "order_number": {
      "type": "string",
      "maxLength": 30,
      "description": "Human-readable order number"
    }
  },
  "required": ["customer_name", "phone", "province", "city", "address", "items", "total_amount", "payment_method"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
