{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orders",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "description": "Unique order number"
    },
    "customer_name": {
      "type": "string",
      "maxLength": 100,
      "description": "Customer full name"
    },
    "customer_email": {
      "type": "string",
      "format": "email",
      "description": "Customer email address"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": { "type": "integer" },
          "product_title": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unit_price": { "type": "number", "minimum": 0 },
          "total_price": { "type": "number", "minimum": 0 }
        }
      },
      "description": "List of ordered items"
    },
    "subtotal": {
      "type": "number",
      "minimum": 0,
      "description": "Order subtotal before tax"
    },
    "tax": {
      "type": "number",
      "minimum": 0,
      "description": "Tax amount"
    },
    "total": {
      "type": "number",
      "minimum": 0,
      "description": "Total order amount"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "paid", "processing", "completed", "cancelled", "refunded"],
      "default": "pending",
      "description": "Order status"
    },
    "payment_method": {
      "type": "string",
      "description": "Payment method used"
    },
    "notes": {
      "type": "string",
      "description": "Additional order notes"
    }
  },
  "required": ["customer_name", "customer_email", "items", "total"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
