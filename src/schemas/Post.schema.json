{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Posts",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Title of the post"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug for the post"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "article", "review"],
      "description": "Category of the post"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "general"],
      "description": "Gaming platform this post is related to"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt of the post"
    },
    "content": {
      "type": "string",
      "description": "Full content/body of the post"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the cover image"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of tags for the post"
    },
    "published": {
      "type": "boolean",
      "default": true,
      "description": "Whether the post is published"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    }
  },
  "required": ["title", "slug", "category", "content"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
