{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todos",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the todo item"
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "The todo item text content"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the todo item is completed"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the todo was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the todo was last updated"
    }
  },
  "required": ["id", "text", "created_at", "updated_at"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}