{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todos",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "The task title"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the task is finished"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Owner of the todo item",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["title"],
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
