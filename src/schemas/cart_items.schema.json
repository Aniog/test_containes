{
  "cart_items": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Cart Items",
    "type": "object",
    "properties": {
      "product_id": { "type": "integer" },
      "quantity": { "type": "integer", "minimum": 1 },
      "price": { "type": "number" },
      "name": { "type": "string" },
      "image_url": { "type": "string" }
    },
    "required": ["product_id", "quantity", "price", "name"]
  }
}
