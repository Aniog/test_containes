{
  "name": "List",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The name/title of the list"
    },
    "board_id": {
      "type": "integer",
      "description": "ID of the board this list belongs to"
    },
    "position": {
      "type": "number",
      "description": "Position order of the list within the board"
    },
    "is_archived": {
      "type": "boolean",
      "description": "Whether the list is archived",
      "default": false
    }
  },
  "required": [
    "title",
    "board_id",
    "position"
  ]
}