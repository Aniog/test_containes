{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "review", "article"],
      "description": "Content category"
    },
    "platform": {
      "type": "string",
      "enum": ["all", "steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Related gaming platform"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt"
    },
    "content": {
      "type": "string",
      "description": "Full article content"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Article tags"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this article is featured on the homepage"
    },
    "view_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of views"
    }
  },
  "required": ["title", "category", "platform", "summary", "author"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] }
  }
}
