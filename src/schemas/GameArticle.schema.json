{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "review", "guide", "announcement"],
      "description": "Article category"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "all"],
      "description": "Related gaming platform"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt"
    },
    "content": {
      "type": "string",
      "description": "Full article content (markdown or HTML)"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Article tags"
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is published"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is featured on the homepage"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    },
    "view_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of views"
    }
  },
  "required": ["title", "category", "platform"],
  "x-security": {
    "create": { "allow": [] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
