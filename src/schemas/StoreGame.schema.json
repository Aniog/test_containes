{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Store Games",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Game title"
    },
    "slug": {
      "type": "string",
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Game description"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "multi"],
      "description": "Game platform"
    },
    "genre": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Game genres"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover/box art image URL"
    },
    "screenshots": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "Screenshot URLs"
    },
    "original_price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Sale/discounted price in USD (null if not on sale)"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Discount percentage"
    },
    "on_sale": {
      "type": "boolean",
      "default": false,
      "description": "Whether the game is currently on sale"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether the game is available for purchase"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the game is featured in the store"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average user rating out of 5"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of reviews"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Game release date"
    },
    "developer": {
      "type": "string",
      "maxLength": 100,
      "description": "Game developer"
    },
    "publisher": {
      "type": "string",
      "maxLength": 100,
      "description": "Game publisher"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Game tags"
    },
    "imgId": {
      "type": "string",
      "maxLength": 100,
      "description": "Unique static image identifier for the Strikingly image system"
    }
  },
  "required": ["title", "platform", "original_price"],
  "x-security": {
    "create": { "allow": [] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
