{
  "name": "Board",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The name/title of the board"
    },
    "description": {
      "type": "string",
      "description": "Optional description of the board's purpose"
    },
    "background_color": {
      "type": "string",
      "description": "Hex color code for board background",
      "default": "#0079bf"
    },
    "is_archived": {
      "type": "boolean",
      "description": "Whether the board is archived",
      "default": false
    },
    "created_by": {
      "type": "string",
      "description": "User ID of the board creator"
    }
  },
  "required": [
    "title",
    "created_by"
  ]
}