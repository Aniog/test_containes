{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Memories",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Short title of the memory"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Full narrative description of the memory"
    },
    "contributor_name": {
      "type": "string",
      "maxLength": 100,
      "description": "Name or alias of the person who contributed this memory"
    },
    "era": {
      "type": "string",
      "enum": ["Ancient", "Medieval", "Industrial", "Modern", "Digital", "Near Future"],
      "description": "Historical era the memory belongs to"
    },
    "year": {
      "type": "integer",
      "minimum": -3000,
      "maximum": 2100,
      "description": "Approximate year of the memory"
    },
    "location_country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country or region where the memory took place"
    },
    "location_city": {
      "type": "string",
      "maxLength": 100,
      "description": "City or locality of the memory"
    },
    "emotion": {
      "type": "string",
      "enum": ["Joy", "Grief", "Wonder", "Love", "Fear", "Nostalgia", "Hope", "Longing", "Pride", "Serenity"],
      "description": "Primary emotion associated with this memory"
    },
    "life_event": {
      "type": "string",
      "enum": ["Birth", "Childhood", "First Love", "Marriage", "Loss", "Achievement", "Migration", "Discovery", "Farewell", "Reunion"],
      "description": "Life event category this memory belongs to"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 50 },
      "maxItems": 10,
      "description": "Additional freeform tags"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this memory is featured on the homepage"
    },
    "view_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of times this memory has been viewed"
    }
  },
  "required": ["title", "description", "era", "emotion", "life_event"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
