{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quote Requests",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person requesting a quote"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Email address to reply to"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Contact phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or organization"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "Double Folding Machine",
        "Double Folder",
        "Sheet Metal Folder",
        "Sheet Metal Folding Machine",
        "Metal Folder",
        "Metal Folder Machine",
        "Metal Folding Machine",
        "Not sure / Need advice"
      ],
      "description": "Which product the lead is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional details about the request"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Lead status used by the sales team"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
