{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Submissions",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the contact"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Email address of the contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone number of the contact"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or organization the contact belongs to"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Message submitted by the contact"
    },
    "status": {
      "type": "string",
      "enum": ["new", "read", "archived"],
      "default": "new",
      "description": "Processing status of the contact submission"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
