{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Store Products",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Game title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly identifier"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Game description"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "multi"],
      "description": "Platform the game is sold on"
    },
    "genre": {
      "type": "string",
      "maxLength": 100,
      "description": "Game genre (e.g. RPG, FPS, Strategy)"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Current price in USD"
    },
    "original_price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price before discount"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Discount percentage (0 if no discount)"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average user rating out of 5"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Game release date"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature on homepage"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether the game is available for purchase"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Game tags"
    }
  },
  "required": ["title", "platform", "price"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
