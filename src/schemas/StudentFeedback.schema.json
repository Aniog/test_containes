{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Student Feedback",
  "type": "object",
  "properties": {
    "student_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the student submitting feedback"
    },
    "class_grade": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Class or grade level of the student (e.g., Grade 10, Physics 101)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Student's email address for follow-up"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "The student's question or feedback message for the teacher"
    },
    "topic": {
      "type": "string",
      "enum": ["constellations", "stellar_evolution", "observational_physics", "gallery", "general"],
      "description": "The astronomy topic the feedback relates to"
    }
  },
  "required": ["student_name", "class_grade", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
