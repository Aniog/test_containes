{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Velmora Jewelry Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Product name"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Price in USD"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "tone": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Gold", "Silver"]
      },
      "description": "Available metal tones"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "storageKey": { "type": "string" },
          "filename": { "type": "string" }
        }
      },
      "description": "Product image gallery"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Flag for featured products"
    },
    "materials": {
      "type": "string",
      "description": "Materials and care information"
    },
    "shipping": {
      "type": "string",
      "description": "Shipping and returns information"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
