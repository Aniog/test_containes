{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for follow-up"
    },
    "phone": {
      "type": "string",
      "maxLength": 20,
      "description": "Phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 100,
      "description": "Product or service of interest"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Inquiry details or message"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of inquiry submission"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
