{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Reference to the user profile"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for contact"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "machine_interest": {
      "type": "string",
      "description": "The specific machine they are interested in"
    },
    "message": {
      "type": "string",
      "minLength": 5,
      "description": "The inquiry message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "replied", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] }
  }
}
