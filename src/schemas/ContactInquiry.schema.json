{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Email address for follow-up"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or organization name"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone number"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country of the inquirer"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "Double Folder",
        "Sheet Metal Folder",
        "Metal Folding Machine",
        "Custom Solution",
        "Not Sure Yet"
      ],
      "description": "Which product the inquirer is interested in"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "description": "Inquiry details, application, sheet size and material"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
