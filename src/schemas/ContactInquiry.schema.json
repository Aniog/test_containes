{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted the inquiry",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person making the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name (optional)"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "The inquiry message content"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
