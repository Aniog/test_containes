{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone number"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 120,
      "description": "Product the inquirer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Inquiry message"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
