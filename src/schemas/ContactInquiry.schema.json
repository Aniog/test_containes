{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person making the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Email address for follow-up"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Optional phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or workshop name"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "Double Folding Machine",
        "Sheet Metal Folder",
        "Metal Folder Machine",
        "Custom Solution",
        "General Inquiry"
      ],
      "description": "Which product the inquiry is about"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Details of the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
