{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Customer Name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Customer Email"
    },
    "company": {
      "type": "string",
      "description": "Company Name"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "double folding machine",
        "double folder",
        "sheet metal folder",
        "sheet metal folding machine",
        "metal folder",
        "metal folder machine",
        "metal folding machine"
      ],
      "description": "Product category of interest"
    },
    "message": {
      "type": "string",
      "minLength": 5,
      "description": "Inquiry message"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Linked User ID"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] },
    "delete": { "allow": ["owner"] },
    "x-ownerColumn": "user_id"
  }
}
