{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person making the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Contact phone number including country code"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or workshop name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country of the customer"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "double-folding-machine",
        "double-folder",
        "sheet-metal-folder",
        "sheet-metal-folding-machine",
        "metal-folder",
        "metal-folder-machine",
        "metal-folding-machine",
        "general-inquiry"
      ],
      "description": "Which product the customer is interested in"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Message or technical requirements"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
