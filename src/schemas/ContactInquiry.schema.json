{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the inquiry"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for response"
    },
    "phone": {
      "type": "string",
      "maxLength": 20,
      "description": "Phone number (optional)"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "Company name (optional)"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 100,
      "description": "Product or service of interest"
    },
    "message": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Detailed inquiry message"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of inquiry submission"
    }
  },
  "required": ["id", "name", "email", "message", "created_at"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
