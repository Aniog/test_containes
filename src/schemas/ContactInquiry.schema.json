{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person sending the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Email address for replies"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Optional phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or studio name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country of operation"
    },
    "interest": {
      "type": "string",
      "enum": [
        "double-folding-machine",
        "sheet-metal-folder",
        "metal-folder-machine",
        "service-and-support",
        "general-enquiry"
      ],
      "description": "Primary area of interest"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "description": "Inquiry message"
    }
  },
  "required": ["name", "email", "interest", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
