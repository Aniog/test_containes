{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Subscriptions",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 254,
      "description": "Subscriber email address"
    },
    "source": {
      "type": "string",
      "enum": ["homepage", "popup", "footer"],
      "default": "homepage",
      "description": "Where on the site the subscription originated"
    },
    "discount_code": {
      "type": "string",
      "maxLength": 32,
      "description": "10% off discount code issued to this subscriber"
    },
    "subscribed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the subscription was created"
    }
  },
  "required": ["email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": [] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
