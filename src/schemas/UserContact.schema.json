{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "User Contacts",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the user"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the user"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the user"
    }
  },
  "required": ["name", "email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] }
  }
}
