{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Testimonials",
  "type": "object",
  "properties": {
    "customer_name": {
      "type": "string",
      "description": "Customer name (first name + initial)"
    },
    "rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "default": 5,
      "description": "Star rating"
    },
    "content": {
      "type": "string",
      "description": "Testimonial text"
    }
  },
  "required": ["customer_name", "content"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] }
  }
}
