{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_category": {
      "type": "string",
      "description": "Category of products they are looking to source"
    },
    "estimated_budget": {
      "type": "string",
      "description": "Estimated budget or order volume"
    },
    "message": {
      "type": "string",
      "description": "Detailed requirements or message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "product_category", "message"],
  "additionalProperties": false,
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] }
  }
}