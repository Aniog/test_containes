{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the person inquiring"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "interest": {
      "type": "string",
      "enum": ["Double Folder", "Metal Folder", "Custom Machine", "Support"],
      "description": "Machine of interest"
    },
    "message": {
      "type": "string",
      "description": "Message or requirements"
    }
  },
  "required": ["email", "name", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}