{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the form"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the person submitting the form"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company name (optional)"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number (optional)"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "Double Folding Machine",
        "Double Folder",
        "Sheet Metal Folder",
        "Sheet Metal Folding Machine",
        "Metal Folder",
        "Metal Folder Machine",
        "Metal Folding Machine",
        "General Inquiry"
      ],
      "description": "Product the customer is interested in"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Message or inquiry details from the customer"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the form was submitted"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
