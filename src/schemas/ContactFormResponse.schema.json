{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "用户姓名"
    },
    "phone": {
      "type": "string",
      "maxLength": 20,
      "description": "手机号码"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "电子邮箱"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "公司/单位名称"
    },
    "subject": {
      "type": "string",
      "enum": ["产品咨询", "合作洽谈", "技术支持", "其他"],
      "description": "咨询主题"
    },
    "message": {
      "type": "string",
      "maxLength": 1000,
      "description": "留言内容"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "关联的用户 ID",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "phone", "email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
