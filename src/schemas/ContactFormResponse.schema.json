{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the form response"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the person contacting us"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for follow-up"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or organization name"
    },
    "product_interest": {
      "type": "string",
      "enum": [
        "double_folding_machine",
        "double_folder",
        "sheet_metal_folder",
        "sheet_metal_folding_machine",
        "metal_folder",
        "metal_folder_machine",
        "metal_folding_machine",
        "general_inquiry"
      ],
      "description": "Product the visitor is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Message or inquiry details"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the response was submitted"
    }
  },
  "required": ["name", "email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
