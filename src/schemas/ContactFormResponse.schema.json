{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person who submitted the form"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Optional phone number of the contact"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Message submitted via the contact form"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
