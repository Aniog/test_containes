{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of the sender"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the sender"
    },
    "subject": {
      "type": "string",
      "description": "Inquiry subject"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the User record"
    },
    "status": {
      "type": "string",
      "enum": ["new", "read", "archived"],
      "default": "new"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
