{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for response"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 200,
      "description": "Products or categories of interest"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed inquiry message"
    },
    "estimated_volume": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order volume"
    },
    "source": {
      "type": "string",
      "maxLength": 100,
      "description": "How they heard about us"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "quoted", "closed"],
      "default": "new",
      "description": "Lead status"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
