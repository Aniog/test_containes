{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Submitter's full name"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Submitter's company name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Submitter's email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Submitter's contact phone number"
    },
    "message": {
      "type": "string",
      "maxLength": 5000,
      "description": "Requirement description or inquiry message"
    },
    "reference_image": {
      "type": "object",
      "description": "Reference image uploaded by the submitter (e.g. product photo, drawing photo)",
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 0 },
        "storageKey": { "type": "string" },
        "storage": { "type": "string" },
        "mimeType": { "type": "string" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      },
      "x-upload": true,
      "x-fileType": "image",
      "x-allowedExtensions": [".jpg", ".jpeg", ".png", ".webp", ".gif"],
      "x-maxFileSize": 10485760,
      "x-mimeTypes": ["image/jpeg", "image/png", "image/webp", "image/gif"]
    },
    "attachment": {
      "type": "object",
      "description": "Technical document or drawing file uploaded by the submitter (e.g. PDF, CAD, Excel)",
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 0 },
        "storageKey": { "type": "string" },
        "storage": { "type": "string" },
        "mimeType": { "type": "string" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      },
      "x-upload": true,
      "x-fileType": "file",
      "x-allowedExtensions": [".pdf", ".doc", ".docx", ".xls", ".xlsx", ".dwg", ".dxf", ".step", ".stp", ".iges", ".igs", ".txt", ".zip", ".rar"],
      "x-maxFileSize": 52428800,
      "x-mimeTypes": [
        "application/pdf",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.ms-excel",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "application/octet-stream",
        "text/plain",
        "application/zip",
        "application/x-rar-compressed"
      ]
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
