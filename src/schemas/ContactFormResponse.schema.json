{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the person submitting the form"
    },
    "email": {
      "type": "string",
      "format": "email",
      "minLength": 1,
      "maxLength": 200,
      "description": "Email address of the submitter"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number of the submitter"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "The message content from the contact form"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] }
  }
}