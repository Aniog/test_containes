{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "machine_interest": {
      "type": "string",
      "description": "Machine they are interested in"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "The inquiry message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "closed"],
      "default": "new",
      "description": "Lead status"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user record",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] },
    "delete": { "allow": ["admin"] }
  }
}
