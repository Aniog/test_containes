{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this form",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "description": "What products are they looking for"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Message or additional details"
    }
  },
  "required": ["user_id", "name", "email", "product_interest", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}