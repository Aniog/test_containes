{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Responses",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "First name of the contact"
    },
    "last_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Last name of the contact"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the contact"
    },
    "country_region_code": {
      "type": "string",
      "maxLength": 10,
      "description": "Country or region code (e.g. HK, JP, US)"
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "description": "City or location of the contact"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Personal or company website URL"
    },
    "facebook": {
      "type": "string",
      "maxLength": 300,
      "description": "Facebook profile URL"
    },
    "twitter": {
      "type": "string",
      "maxLength": 300,
      "description": "Twitter profile URL"
    },
    "instagram": {
      "type": "string",
      "maxLength": 300,
      "description": "Instagram profile URL"
    },
    "youtube": {
      "type": "string",
      "maxLength": 300,
      "description": "YouTube channel URL"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Message or inquiry from the contact"
    }
  },
  "required": ["first_name", "last_name", "email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
