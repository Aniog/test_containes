{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the CRM user created or updated for this inquiry",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the overseas buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address for follow-up"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Buyer company name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer country or market"
    },
    "product_category": {
      "type": "string",
      "maxLength": 120,
      "description": "Main product category the buyer wants to source"
    },
    "service_needed": {
      "type": "string",
      "enum": ["supplier_sourcing", "factory_verification", "quality_inspection", "production_follow_up", "shipping_coordination", "complete_sourcing_project"],
      "description": "Primary sourcing service requested"
    },
    "quantity": {
      "type": "string",
      "maxLength": 120,
      "description": "Estimated order quantity or target volume"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Project details, requirements, timeline, or questions"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "email", "product_category", "service_needed", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
