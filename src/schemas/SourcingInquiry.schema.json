{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 150,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "product_type": {
      "type": "string",
      "maxLength": 200,
      "description": "Type or category of product to be sourced"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed description of the product, specifications, and requirements"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Target order quantity or MOQ"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Private Label / OEM"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Expected delivery or project timeline"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Any additional information or special requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "contacted", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["full_name", "email", "product_type", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
