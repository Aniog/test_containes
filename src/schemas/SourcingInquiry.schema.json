{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "The name of the enquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_type": {
      "type": "string",
      "description": "Type of product to source"
    },
    "estimated_quantity": {
      "type": "string",
      "description": "Estimated annual or per-order quantity"
    },
    "message": {
      "type": "string",
      "description": "Detailed sourcing requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Inquiry follow-up status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["name", "email", "product_type", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
