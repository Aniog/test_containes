{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "product": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Product name or description the buyer wants to source"
    },
    "category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Goods",
        "Apparel & Textiles",
        "Industrial Machinery & Tools",
        "Packaging & Printing",
        "Toys & Baby Products",
        "Health & Beauty",
        "Automotive Parts",
        "Sports & Outdoor",
        "Other"
      ],
      "description": "Product category"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or total budget range"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Compliance & Documentation"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional details, requirements, or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "quoted", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "product"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
