{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the buyer or contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Decor",
        "Clothing & Textiles",
        "Machinery & Industrial",
        "Toys & Baby Products",
        "Health & Beauty",
        "Sports & Outdoor",
        "Packaging & Printing",
        "Auto Parts",
        "Other"
      ],
      "description": "Product category the buyer is interested in sourcing"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed description of the product(s) the buyer wants to source"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 200,
      "description": "Estimated order quantity or annual volume"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Sample Procurement"
        ]
      },
      "description": "Services the buyer requires"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional notes or requirements from the buyer"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
