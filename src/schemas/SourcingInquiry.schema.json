{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the buyer"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp (optional)"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer country"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer electronics",
        "Home & kitchen",
        "Apparel & textiles",
        "Promotional & gifts",
        "Industrial & hardware",
        "Beauty & personal care",
        "Toys & baby",
        "Furniture & lighting",
        "Sports & outdoors",
        "Other"
      ],
      "description": "Product category to source"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "description": "Description of the product, specs, target unit price"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 80,
      "description": "Target order quantity or MOQ expectation"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier search",
          "Factory verification",
          "Sample management",
          "Price negotiation",
          "Production follow-up",
          "Quality inspection",
          "Shipping & logistics"
        ]
      },
      "uniqueItems": true,
      "description": "Sourcing services needed"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "Within 2 weeks",
        "Within 1 month",
        "1-3 months",
        "Flexible / planning ahead"
      ],
      "description": "Desired timeline"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Internal inquiry status"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["full_name", "email", "product_category", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
