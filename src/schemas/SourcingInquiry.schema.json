{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Contact phone number (optional)"
    },
    "product_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Name or description of the product to be sourced"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Décor",
        "Apparel & Textiles",
        "Machinery & Industrial",
        "Toys & Baby Products",
        "Health & Beauty",
        "Sports & Outdoor",
        "Packaging & Labels",
        "Auto Parts",
        "Hardware & Tools",
        "Food & Agriculture",
        "Other"
      ],
      "description": "Product category"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity (e.g. 500 units, 1 container)"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range (optional)"
    },
    "service_needed": {
      "type": "string",
      "enum": [
        "Supplier Sourcing",
        "Factory Verification",
        "Quality Inspection",
        "Production Follow-up",
        "Shipping Coordination",
        "Private Label / OEM",
        "Full Sourcing Service"
      ],
      "description": "Primary service required"
    },
    "message": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Additional details about the sourcing requirement"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_name", "service_needed", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
