{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Full name of the buyer or contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number (optional)"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Decor",
        "Apparel & Textiles",
        "Industrial Machinery",
        "Toys & Baby Products",
        "Beauty & Personal Care",
        "Sports & Outdoor",
        "Packaging & Printing",
        "Automotive Parts",
        "Kitchenware & Cookware",
        "Medical & Health Devices",
        "Pet Products",
        "Other"
      ],
      "description": "Product category the buyer is interested in sourcing"
    },
    "product_description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Detailed description of the product the buyer wants to source"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity (e.g. 500 units, 1 container)"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range (optional)"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Audit",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Private Label / OEM"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional notes or requirements from the buyer"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
