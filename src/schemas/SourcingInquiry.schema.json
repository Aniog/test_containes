{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiry",
  "description": "Sourcing inquiries from potential clients",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone or WhatsApp number"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed description of the product needed"
    },
    "product_category": {
      "type": "string",
      "maxLength": 100,
      "description": "Category of the product"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Target order quantity"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Budget per unit or total budget"
    },
    "timeline": {
      "type": "string",
      "maxLength": 50,
      "description": "Required delivery timeline"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of services the client is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional message or details"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_progress", "quoted", "converted", "closed"],
      "description": "Status of the inquiry"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Internal notes about the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was last updated"
    }
  },
  "required": ["name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}