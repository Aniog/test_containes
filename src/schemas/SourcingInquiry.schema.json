{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the inquiry"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country of the buyer"
    },
    "product_category": {
      "type": "string",
      "maxLength": 120,
      "description": "Product category or type they want to source"
    },
    "estimated_volume": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order volume or quantity"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed sourcing requirements or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "quoted", "closed"],
      "default": "new",
      "description": "Current status of the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was last updated"
    }
  },
  "required": ["id", "name", "email", "company", "country", "product_category", "message", "status", "created_at", "updated_at"],
  "additionalProperties": false
}
