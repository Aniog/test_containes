{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company_name": {
      "type": "string",
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "description": "The product or category they are interested in sourcing"
    },
    "estimated_volume": {
      "type": "string",
      "description": "Estimated order volume or quantity"
    },
    "message": {
      "type": "string",
      "description": "Detailed sourcing requirements or message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "archived"],
      "default": "new",
      "description": "Lead status"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user record (CRM)",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "product_interest"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
