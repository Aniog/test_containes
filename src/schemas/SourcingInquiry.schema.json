{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person submitting the inquiry"
    },
    "company_name": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or brand name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp number including country code"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country where the buyer is based"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer Electronics",
        "Home & Kitchen",
        "Apparel & Textiles",
        "Promotional & Gifts",
        "Industrial & Hardware",
        "Beauty & Personal Care",
        "Sports & Outdoor",
        "Furniture",
        "Auto Parts",
        "Other"
      ],
      "description": "Main product category the buyer is sourcing"
    },
    "product_description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 2000,
      "description": "Free-text description of the product the buyer wants to source"
    },
    "estimated_order_quantity": {
      "type": "string",
      "maxLength": 120,
      "description": "Estimated MOQ or order quantity (e.g. 500 units, 1x20ft container)"
    },
    "target_unit_price": {
      "type": "string",
      "maxLength": 60,
      "description": "Target unit price or budget range (e.g. USD 4-6 per unit)"
    },
    "needed_services": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Sample Management",
          "Price Negotiation",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping & Logistics",
          "Private Labeling"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "Within 2 weeks",
        "Within 1 month",
        "1-3 months",
        "Just exploring"
      ],
      "description": "When the buyer wants to begin sourcing"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional notes or context provided by the buyer"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Internal lifecycle status for the inquiry"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
