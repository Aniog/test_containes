{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "product": {
      "type": "string",
      "maxLength": 200,
      "description": "Product or category they want to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target budget or price range"
    },
    "service": {
      "type": "string",
      "enum": ["supplier_sourcing", "factory_audit", "quality_inspection", "production_followup", "shipping", "full_service", "other"],
      "description": "Primary service requested"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional details or requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["name", "email", "product", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": [] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
