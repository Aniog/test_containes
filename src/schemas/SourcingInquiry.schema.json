{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the CRM user record for the buyer contact",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the buyer contact"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Buyer email address for follow-up"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country or market where the buyer is based"
    },
    "product_category": {
      "type": "string",
      "maxLength": 140,
      "description": "Product category or item the buyer wants to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 120,
      "description": "Estimated order quantity or purchasing volume"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier sourcing", "Factory verification", "Quality inspection", "Production follow-up", "Shipping coordination", "Other"]
      },
      "description": "Sourcing support services requested by the buyer"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Project details, requirements, target price, standards, or questions"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "email", "product_category", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
