{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person making the inquiry"
    },
    "company_name": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Contact phone number including country code"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Description of products to source"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 200,
      "description": "Estimated order quantity"
    },
    "target_price": {
      "type": "string",
      "maxLength": 200,
      "description": "Target price range or budget"
    },
    "timeline": {
      "type": "string",
      "maxLength": 500,
      "description": "Expected timeline for sourcing"
    },
    "additional_info": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional information or requirements"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false
}