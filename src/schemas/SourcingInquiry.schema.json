{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Contact person name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_category": {
      "type": "string",
      "enum": ["Electronics", "Furniture", "Textiles", "Machinery", "Home Goods", "Other"],
      "description": "Interested product category"
    },
    "estimated_annual_volume": {
      "type": "string",
      "description": "Estimated annual sourcing volume"
    },
    "message": {
      "type": "string",
      "description": "Detailed sourcing requirements or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "archived"],
      "default": "new",
      "description": "Lead status"
    }
  },
  "required": ["name", "email", "product_category", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
