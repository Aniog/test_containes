{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the buyer"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "product_type": {
      "type": "string",
      "maxLength": 200,
      "description": "Type or category of product to be sourced"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Detailed description of the product including specifications"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Target order quantity or MOQ"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier Sourcing", "Factory Verification", "Quality Inspection", "Production Follow-up", "Shipping Coordination", "Sample Management"]
      },
      "description": "Services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Expected delivery or project timeline"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Any additional information or requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["name", "email", "product_type", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": [] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
