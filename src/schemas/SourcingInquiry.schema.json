{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiry",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "company": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Company name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for correspondence"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number for contact"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 200,
      "description": "Category of products the inquirer is interested in sourcing"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated quantity needed"
    },
    "message": {
      "type": "string",
      "maxLength": 5000,
      "description": "Detailed message describing product requirements and other information"
    },
    "status": {
      "type": "string",
      "enum": ["new", "reviewed", "responded", "closed"],
      "default": "new",
      "description": "Status of the inquiry in the workflow"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "company", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
