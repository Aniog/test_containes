{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country where the buyer is based"
    },
    "product_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 200,
      "description": "Name or description of the product to be sourced"
    },
    "product_category": {
      "type": "string",
      "enum": ["Electronics", "Furniture", "Apparel & Textiles", "Industrial & Machinery", "Home & Kitchen", "Health & Beauty", "Toys & Sporting Goods", "Packaging & Print", "Other"],
      "description": "Product category"
    },
    "order_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity (e.g. 500 units, 1000 pcs)"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range (e.g. USD 5–8 per unit)"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier Sourcing", "Factory Verification", "Quality Inspection", "Production Follow-up", "Shipping Coordination", "Trade Compliance"]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional details, requirements, or questions"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_name"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
