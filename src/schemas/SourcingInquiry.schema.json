{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Contact person name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "description": "Products they are looking for"
    },
    "order_quantity": {
      "type": "string",
      "description": "Estimated order quantity"
    },
    "message": {
      "type": "string",
      "description": "Detailed requirements or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Inquiry status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission time"
    }
  },
  "required": ["name", "email", "product_interest"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
