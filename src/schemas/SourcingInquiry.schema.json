{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country where the buyer is based"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Tech",
        "Furniture & Home",
        "Apparel & Textiles",
        "Industrial & Hardware",
        "Health & Beauty",
        "Toys & Gifts",
        "Food & Agriculture",
        "Other"
      ],
      "description": "Product category the buyer is interested in sourcing"
    },
    "product_description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Description of the product the buyer wants to source, including specs and requirements"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ range"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Private Label / OEM"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional information or questions from the buyer"
    },
    "how_did_you_hear": {
      "type": "string",
      "maxLength": 100,
      "description": "How the buyer found SSourcing China"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
