{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the buyer making the inquiry"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or business name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp number, including country code"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country where the buyer is based"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer Electronics",
        "Apparel & Textiles",
        "Home & Kitchen",
        "Furniture",
        "Beauty & Personal Care",
        "Industrial & Hardware",
        "Toys & Baby",
        "Sports & Outdoors",
        "Auto Parts & Accessories",
        "Packaging",
        "Other"
      ],
      "description": "Main product category to source"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Description of the product the buyer wants to source, including specs, materials and any reference links"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "target_budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or total budget"
    },
    "needed_services": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Sample Management",
          "Price Negotiation",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping & Logistics",
          "Private Label / OEM"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "ASAP (within 30 days)",
        "1 - 3 months",
        "3 - 6 months",
        "Just exploring"
      ],
      "description": "How soon the buyer wants to start"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Time the inquiry was submitted"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
