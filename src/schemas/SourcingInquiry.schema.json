{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or organization name"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number with country code"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "description": "Description of the product to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Expected order quantity"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Monitoring",
          "Shipping Coordination",
          "Custom Product Development"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "budget_range": {
      "type": "string",
      "maxLength": 100,
      "description": "Approximate budget or target price range"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Expected timeline for the project"
    },
    "message": {
      "type": "string",
      "description": "Additional details or questions"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
