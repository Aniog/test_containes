{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Description of the product to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target budget or price range"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Target delivery timeline"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional message or requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "converted", "archived"],
      "description": "Inquiry status"
    }
  },
  "required": ["name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}