{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted the inquiry",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number"
    },
    "product": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Product the inquirer wants to source from China"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Detailed requirements and message from the inquirer"
    }
  },
  "required": ["name", "email", "product", "message"],
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] },
    "delete": { "allow": ["owner"] }
  }
}
