{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for correspondence"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "productType": {
      "type": "string",
      "description": "Type of product to source"
    },
    "quantity": {
      "type": "string",
      "description": "Estimated order quantity"
    },
    "requirements": {
      "type": "string",
      "description": "Specific requirements or message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "quoted", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    }
  },
  "required": ["name", "email", "productType"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
