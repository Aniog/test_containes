{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Contact person full name"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or brand name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp number with country code"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country or region of the buyer"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer Electronics",
        "Home & Kitchen",
        "Apparel & Textiles",
        "Industrial & Hardware",
        "Beauty & Personal Care",
        "Sports & Outdoors",
        "Toys & Baby",
        "Promotional & Gifts",
        "Other"
      ],
      "description": "Primary product category to source"
    },
    "product_description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 2000,
      "description": "Description of the product and requirements"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 80,
      "description": "Estimated order quantity per SKU"
    },
    "target_unit_price": {
      "type": "string",
      "maxLength": 80,
      "description": "Target unit price (e.g. USD 3.50 EXW)"
    },
    "services_needed": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Audit",
          "Sample Management",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping & Logistics",
          "Private Label / OEM",
          "Amazon FBA Prep"
        ]
      },
      "description": "Sourcing services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "Within 2 weeks",
        "Within 1 month",
        "1-3 months",
        "Just exploring"
      ],
      "description": "When the buyer wants to start"
    },
    "status": {
      "type": "string",
      "enum": ["new", "reviewing", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
