{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or brand name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer country / region"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp / WeChat number"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "consumer-electronics",
        "home-kitchen",
        "apparel-textiles",
        "promotional-gifts",
        "industrial-hardware",
        "beauty-personal-care",
        "outdoor-sports",
        "packaging",
        "furniture",
        "other"
      ],
      "description": "Primary product category to source"
    },
    "product_description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 4000,
      "description": "Description of the product and key requirements"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 80,
      "description": "Estimated order quantity or MOQ target"
    },
    "target_budget": {
      "type": "string",
      "maxLength": 80,
      "description": "Target unit price or total budget"
    },
    "services_needed": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "supplier-search",
          "factory-audit",
          "sample-management",
          "price-negotiation",
          "production-follow-up",
          "quality-inspection",
          "shipping-logistics",
          "private-label"
        ]
      },
      "description": "Sourcing services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "enum": ["immediate", "1-3-months", "3-6-months", "exploring"],
      "description": "Expected sourcing timeline"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
