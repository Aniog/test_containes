{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the inquiry"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company or organization name"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number with country code"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Buyer country or region"
    },
    "product_category": {
      "type": "string",
      "maxLength": 100,
      "description": "Product category of interest"
    },
    "budget_range": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order volume or budget"
    },
    "message": {
      "type": "string",
      "minLength": 10,
      "maxLength": 5000,
      "description": "Detailed sourcing requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Inquiry status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
