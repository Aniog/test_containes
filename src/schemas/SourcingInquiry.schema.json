{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Contact person name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "productName": {
      "type": "string",
      "description": "Name of the product to source"
    },
    "quantity": {
      "type": "string",
      "description": "Expected order quantity"
    },
    "targetPrice": {
      "type": "string",
      "description": "Target unit price (USD)"
    },
    "requirements": {
      "type": "string",
      "description": "Detailed sourcing requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "processing", "quoted", "closed"],
      "default": "new",
      "description": "Inquiry status"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Submission time"
    }
  },
  "required": ["name", "email", "productName"],
  "x-security": {
    "create": {
      "allow": ["*"]
    },
    "read": {
      "allow": ["admin"]
    },
    "update": {
      "allow": ["admin"]
    },
    "delete": {
      "allow": ["admin"]
    }
  }
}
