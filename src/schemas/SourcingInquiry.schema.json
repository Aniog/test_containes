{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person requesting the sourcing quote."
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Email address used to reply to the inquiry."
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or business name of the buyer."
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country the buyer is based in."
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Optional phone or WhatsApp number."
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer Electronics",
        "Home & Living",
        "Apparel & Textiles",
        "Promotional Products & Gifts",
        "Hardware & Tools",
        "Beauty & Personal Care",
        "Other"
      ],
      "description": "Primary product category the buyer wants to source."
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Description of the product to be sourced, including specs and target price if known."
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 60,
      "description": "Estimated order quantity or range, e.g. 5000 pcs."
    },
    "target_lead_time": {
      "type": "string",
      "maxLength": 60,
      "description": "Desired delivery timeframe, e.g. within 60 days."
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification & Audit",
          "Quality Control Inspection",
          "Production Follow-Up",
          "Shipping & Logistics Coordination",
          "End-to-End Order Management"
        ]
      },
      "description": "Sourcing services the buyer is interested in."
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional notes or questions from the buyer."
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "quoted", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry."
    }
  },
  "required": ["name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
