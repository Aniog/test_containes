{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number"
    },
    "product_category": {
      "type": "string",
      "enum": ["Electronics & Components", "Textiles & Apparel", "Machinery & Equipment", "Home & Garden", "Auto Parts", "Packaging & Printing", "Building Materials", "Health & Beauty", "Other"],
      "description": "Product category of interest"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Description of the product to be sourced"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier Sourcing", "Factory Verification", "Quality Inspection", "Production Follow-up", "Shipping Coordination", "Cost Optimization"]
      },
      "description": "Services requested"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional message or requirements"
    }
  },
  "required": ["name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
