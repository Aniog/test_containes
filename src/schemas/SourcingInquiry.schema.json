{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "Full name of the buyer or contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number (optional)"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Goods",
        "Apparel & Textiles",
        "Industrial Machinery",
        "Packaging & Printing",
        "Toys & Baby Products",
        "Beauty & Personal Care",
        "Auto Parts & Accessories",
        "Sports & Outdoor",
        "Medical & Health Devices",
        "Pet Products",
        "Building & Construction",
        "Other"
      ],
      "description": "Product category being sourced"
    },
    "product_description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Description of the product to be sourced, including specifications, materials, and any special requirements"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity (e.g. 500 units, 1000 pcs/month)"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range (optional)"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Supplier Negotiation"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "As soon as possible",
        "Within 1 month",
        "1–3 months",
        "3–6 months",
        "Just exploring"
      ],
      "description": "Buyer's expected timeline for the project"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 1000,
      "description": "Any additional information or questions"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
