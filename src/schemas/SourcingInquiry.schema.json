{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique inquiry identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the buyer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 120,
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 120,
      "description": "Company or brand name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer country"
    },
    "product_category": {
      "type": "string",
      "maxLength": 100,
      "description": "Category of product being sourced"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Detailed product description and requirements"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target price range or unit price"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional questions or notes"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    }
  },
  "required": ["name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
