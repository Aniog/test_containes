{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_details": {
      "type": "string",
      "description": "Detailed description of products to source"
    },
    "estimated_quantity": {
      "type": "string",
      "description": "Estimated target quantity"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "quoted", "closed"],
      "default": "new",
      "description": "Inquiry status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when inquiry was submitted"
    }
  },
  "required": ["name", "email", "product_details"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] }
  }
}
