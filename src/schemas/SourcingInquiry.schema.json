{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name (optional)"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number (optional)"
    },
    "product_description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Description of the product to be sourced"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "target_budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target budget range"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Target timeline for sourcing"
    },
    "additional_message": {
      "type": "string",
      "maxLength": 5000,
      "description": "Additional details or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "converted", "closed"],
      "default": "new",
      "description": "Lead status tracking"
    }
  },
  "required": ["name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] }
  }
}