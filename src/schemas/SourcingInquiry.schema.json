{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "Company name"
    },
    "product_details": {
      "type": "string",
      "minLength": 1,
      "description": "Details about the product they want to source"
    },
    "quantity": {
      "type": "string",
      "description": "Estimated order quantity"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this form",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "product_details"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}