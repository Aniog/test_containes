{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "description": "Phone number or WhatsApp"
    },
    "product": {
      "type": "string",
      "description": "Product(s) the buyer is interested in sourcing"
    },
    "quantity": {
      "type": "string",
      "description": "Estimated order quantity"
    },
    "message": {
      "type": "string",
      "description": "Details about the sourcing request"
    },
    "status": {
      "type": "string",
      "enum": ["new", "processed", "replied"],
      "default": "new"
    }
  },
  "required": ["name", "email", "product", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}