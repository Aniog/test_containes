{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the buyer or contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country where the buyer is based"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Contact phone number (optional)"
    },
    "product_description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000,
      "description": "Description of the product the buyer wants to source"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "service_needed": {
      "type": "string",
      "enum": ["full_sourcing", "supplier_only", "factory_audit", "quality_inspection", "shipping_only", "consulting", "other"],
      "description": "Primary service the buyer is requesting"
    },
    "timeline": {
      "type": "string",
      "maxLength": 200,
      "description": "Desired delivery or project timeline"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 3000,
      "description": "Any additional requirements, certifications needed, or context"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user record in the Users table",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_description", "service_needed"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
