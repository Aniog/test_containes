{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    },
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "product_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name or description of the product to source"
    },
    "product_category": {
      "type": "string",
      "enum": ["Electronics", "Furniture & Home", "Apparel & Textiles", "Industrial & Hardware", "Toys & Sports", "Beauty & Health", "Packaging", "Other"],
      "description": "Product category"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Target order quantity or MOQ"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier Sourcing", "Factory Verification", "Quality Inspection", "Production Follow-up", "Shipping Coordination", "Private Label / OEM"]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Additional details or requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["full_name", "email", "product_name"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
