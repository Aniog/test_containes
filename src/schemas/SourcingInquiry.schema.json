{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact person"
    },
    "company": {
      "type": "string",
      "minLength": 1,
      "maxLength": 150,
      "description": "Company or business name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone or WhatsApp number"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "productDescription": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Description of products they want to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Target order quantity or volume"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Expected timeline for the order"
    },
    "source": {
      "type": "string",
      "maxLength": 100,
      "description": "How they heard about SSourcing China"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when inquiry was submitted"
    }
  },
  "required": ["name", "company", "email", "productDescription"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
