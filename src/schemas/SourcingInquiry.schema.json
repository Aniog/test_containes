{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Linked user ID",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Contact person name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "description": "Products they want to source"
    },
    "estimated_quantity": {
      "type": "string",
      "description": "Estimated order quantity"
    },
    "message": {
      "type": "string",
      "description": "Detailed requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "archived"],
      "default": "new",
      "description": "Status of the inquiry"
    }
  },
  "required": ["name", "email", "product_interest"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] }
  },
  "x-ownerColumn": "user_id"
}
