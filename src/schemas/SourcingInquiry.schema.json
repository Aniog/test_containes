{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the buyer submitting the sourcing inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address for follow-up"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company name of the buyer"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer country or market"
    },
    "product_category": {
      "type": "string",
      "maxLength": 120,
      "description": "Product category or item the buyer wants to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 80,
      "description": "Estimated order quantity or purchasing volume"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Supplier sourcing", "Factory verification", "Quality inspection", "Production follow-up", "Shipping coordination", "Other"]
      },
      "description": "Services requested by the buyer"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Detailed sourcing requirements, product notes, and timeline"
    },
    "preferred_contact": {
      "type": "string",
      "enum": ["Email", "WhatsApp", "WeChat", "Phone"],
      "default": "Email",
      "description": "Preferred contact channel"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the inquiry was submitted"
    }
  },
  "required": ["name", "email", "product_category", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": {
      "allow": ["*"]
    }
  }
}
