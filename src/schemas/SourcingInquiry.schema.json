{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the inquirer"
    },
    "product_of_interest": {
      "type": "string",
      "maxLength": 500,
      "description": "Product or category the inquirer is looking to source"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated quantity needed"
    },
    "budget_range": {
      "type": "string",
      "maxLength": 200,
      "description": "Target budget range"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Detailed sourcing requirements description"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "converted", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] }
  }
}