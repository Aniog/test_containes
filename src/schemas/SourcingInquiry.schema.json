{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country where the buyer is based"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "service_needed": {
      "type": "string",
      "enum": ["supplier_sourcing", "factory_verification", "quality_inspection", "production_followup", "shipping_coordination", "private_label_oem", "full_service", "not_sure"],
      "description": "Primary service the buyer is interested in"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Description of the product(s) the buyer wants to source"
    },
    "target_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "timeline": {
      "type": "string",
      "maxLength": 200,
      "description": "Desired delivery or project timeline"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 3000,
      "description": "Any additional requirements, certifications needed, or questions"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
