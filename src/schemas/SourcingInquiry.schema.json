{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the inquirer"
    },
    "product": {
      "type": "string",
      "maxLength": 500,
      "description": "Product they want to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Target budget range"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Target timeline for delivery"
    },
    "message": {
      "type": "string",
      "maxLength": 5000,
      "description": "Additional project details"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Inquiry status"
    }
  },
  "required": ["name", "email", "product", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}