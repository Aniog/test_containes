{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company name"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country"
    },
    "product_category": {
      "type": "string",
      "maxLength": 120,
      "description": "Product category or type"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Sourcing requirements or message"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
