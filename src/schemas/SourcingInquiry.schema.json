{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person making the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for contact"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone number or WhatsApp"
    },
    "product": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Product the buyer wants to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 200,
      "description": "Estimated order quantity"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional details about the sourcing requirements"
    }
  },
  "required": ["name", "email", "product"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}