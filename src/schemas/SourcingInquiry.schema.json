{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the buyer or contact person"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or brand name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Phone or WhatsApp number including country code"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Buyer's country or region"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Consumer Electronics",
        "Home & Kitchen",
        "Apparel & Textiles",
        "Furniture",
        "Beauty & Personal Care",
        "Sports & Outdoor",
        "Toys & Baby",
        "Industrial & Hardware",
        "Packaging",
        "Pet Supplies",
        "Other"
      ],
      "description": "Main product category to source"
    },
    "service_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Sample Management",
          "Price Negotiation",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping & Logistics",
          "Private Label / OEM"
        ]
      },
      "uniqueItems": true,
      "description": "Services the buyer is interested in"
    },
    "order_volume": {
      "type": "string",
      "enum": [
        "Under 1,000 USD",
        "1,000 - 10,000 USD",
        "10,000 - 50,000 USD",
        "50,000 - 200,000 USD",
        "200,000+ USD"
      ],
      "description": "Estimated first order value"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "ASAP (within 30 days)",
        "1-3 months",
        "3-6 months",
        "Planning / Exploring"
      ],
      "description": "When the buyer plans to place the order"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000,
      "description": "Project description, target specs or supplier requirements"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Submission timestamp"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
