{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number (optional)"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Goods",
        "Apparel & Textiles",
        "Toys & Baby Products",
        "Hardware & Tools",
        "Packaging Materials",
        "Sporting Goods",
        "Industrial Equipment",
        "Cosmetics & Personal Care",
        "Food & Beverage Packaging",
        "Other"
      ],
      "description": "Product category the buyer is interested in sourcing"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Description of the product the buyer wants to source, including specs and requirements"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Trade Compliance"
        ]
      },
      "description": "Services the buyer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 3000,
      "description": "Additional information or questions from the buyer"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "responded", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
