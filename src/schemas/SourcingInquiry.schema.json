{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the buyer or contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or business name"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone or WhatsApp number"
    },
    "product_category": {
      "type": "string",
      "enum": [
        "Electronics & Components",
        "Furniture & Home Decor",
        "Clothing & Textiles",
        "Machinery & Industrial",
        "Toys & Baby Products",
        "Health & Beauty",
        "Sports & Outdoor",
        "Packaging & Printing",
        "Auto Parts",
        "Other"
      ],
      "description": "Product category the buyer is sourcing"
    },
    "product_description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Description of the product(s) the buyer wants to source"
    },
    "estimated_quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity or MOQ requirement"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target unit price or budget range"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Verification",
          "Quality Inspection",
          "Production Follow-up",
          "Shipping Coordination",
          "Private Label / OEM",
          "Sample Procurement"
        ]
      },
      "description": "Services the buyer requires"
    },
    "timeline": {
      "type": "string",
      "enum": [
        "ASAP (within 2 weeks)",
        "1 month",
        "2-3 months",
        "Flexible"
      ],
      "description": "Expected sourcing timeline"
    },
    "additional_notes": {
      "type": "string",
      "maxLength": 3000,
      "description": "Any additional requirements or notes from the buyer"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "closed"],
      "default": "new",
      "description": "Internal status of the inquiry"
    }
  },
  "required": ["full_name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
