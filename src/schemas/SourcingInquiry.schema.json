{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number of the inquirer"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 500,
      "description": "Products the inquirer is interested in sourcing"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "budget": {
      "type": "string",
      "maxLength": 100,
      "description": "Budget range for the sourcing project"
    },
    "timeline": {
      "type": "string",
      "maxLength": 100,
      "description": "Target timeline for the project"
    },
    "message": {
      "type": "string",
      "maxLength": 5000,
      "description": "Detailed requirements and message from the inquirer"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}