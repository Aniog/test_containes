{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "review", "guide"],
      "description": "Article category"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt"
    },
    "content": {
      "type": "string",
      "description": "Full article content (HTML or markdown)"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of tags"
    },
    "platform": {
      "type": "string",
      "enum": ["all", "steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Related gaming platform"
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is published"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature on homepage"
    }
  },
  "required": ["title", "category", "content", "author"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] }
  }
}
