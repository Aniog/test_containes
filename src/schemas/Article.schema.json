{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "category": {
      "type": "string",
      "enum": ["news", "article", "review", "guide"],
      "description": "Content category"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt"
    },
    "content": {
      "type": "string",
      "description": "Full article content"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for the article"
    },
    "platform": {
      "type": "string",
      "enum": ["all", "steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Related gaming platform"
    },
    "published": {
      "type": "boolean",
      "default": true,
      "description": "Whether the article is published"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is featured on the homepage"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    }
  },
  "required": ["title", "category", "summary", "content", "author"],
  "x-security": {
    "create": { "allow": [] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
