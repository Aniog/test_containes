{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Title of the article"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug for the article"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "review", "guide", "announcement"],
      "description": "Category of the article"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary or excerpt of the article"
    },
    "content": {
      "type": "string",
      "description": "Full content of the article in markdown or HTML"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the cover image"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags associated with the article"
    },
    "platform": {
      "type": "string",
      "enum": ["all", "steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Gaming platform this article is related to"
    },
    "published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is published"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    },
    "views": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of views"
    }
  },
  "required": ["title", "category", "content"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
