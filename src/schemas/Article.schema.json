{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "review", "guide"],
      "description": "Article category"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary of the article"
    },
    "content": {
      "type": "string",
      "description": "Full article content"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for the article"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this article is featured on the homepage"
    }
  },
  "required": ["title", "category", "summary", "author"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
