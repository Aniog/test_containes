{
  "name": "Article",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Article title"
    },
    "content": {
      "type": "string",
      "description": "Article content in markdown format"
    },
    "excerpt": {
      "type": "string",
      "description": "Short article excerpt"
    },
    "author": {
      "type": "string",
      "description": "Article author name"
    },
    "category": {
      "type": "string",
      "enum": ["Review", "Guide", "News", "Opinion", "Interview"],
      "description": "Article category"
    },
    "featured_image": {
      "type": "string",
      "description": "Article featured image URL"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Article tags"
    },
    "published_date": {
      "type": "string",
      "format": "date",
      "description": "Article publication date"
    },
    "is_featured": {
      "type": "boolean",
      "description": "Whether the article is featured"
    },
    "read_time": {
      "type": "integer",
      "description": "Estimated read time in minutes"
    },
    "related_games": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Related game titles"
    }
  },
  "required": [
    "title",
    "content",
    "excerpt",
    "author",
    "category",
    "published_date"
  ]
}