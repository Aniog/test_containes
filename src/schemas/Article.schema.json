{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "excerpt": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary of the article"
    },
    "content": {
      "type": "string",
      "description": "Full article content in plain text or markdown"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "article", "review"],
      "description": "Content category"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "general"]
      },
      "description": "Related gaming platforms"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Searchable tags"
    },
    "cover_image": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this article is featured on the homepage"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    }
  },
  "required": ["title", "slug", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
