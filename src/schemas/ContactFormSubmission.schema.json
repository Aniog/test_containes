{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Submissions",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the contact (optional)"
    },
    "subject": {
      "type": "string",
      "maxLength": 200,
      "description": "Subject or reason for getting in touch"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "The message body from the contact"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user record in the Users table",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
