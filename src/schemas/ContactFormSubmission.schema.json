{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Submissions",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user record",
      "x-foreignKey": "users.id"
    },
    "name": {
      "type": "string",
      "description": "Sender's full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Sender's email address"
    },
    "subject": {
      "type": "string",
      "description": "Reason for contact"
    },
    "message": {
      "type": "string",
      "description": "Message content"
    },
    "product_interest": {
      "type": "string",
      "description": "Product the user is interested in"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] }
  }
}
