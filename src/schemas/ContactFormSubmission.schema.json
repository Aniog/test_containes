{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Submission",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name (optional)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 200,
      "description": "Business email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number with country code (optional)"
    },
    "country": {
      "type": "string",
      "maxLength": 80,
      "description": "Country or region the buyer is based in"
    },
    "industry": {
      "type": "string",
      "maxLength": 80,
      "description": "Product category or industry for the inquiry"
    },
    "product": {
      "type": "string",
      "maxLength": 200,
      "description": "Short product description"
    },
    "quantity": {
      "type": "string",
      "maxLength": 80,
      "description": "Target order quantity or MOQ requirement"
    },
    "message": {
      "type": "string",
      "maxLength": 4000,
      "description": "Additional project details, specs, timeline"
    },
    "source_page": {
      "type": "string",
      "maxLength": 200,
      "description": "Page on the website where the inquiry was submitted"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false
}