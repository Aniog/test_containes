{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Form Submissions",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the person submitting the inquiry"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name of the person submitting the inquiry"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number or WhatsApp number"
    },
    "product_details": {
      "type": "string",
      "minLength": 1,
      "description": "Details about the product they want to source"
    },
    "quantity": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order quantity"
    },
    "target_price": {
      "type": "string",
      "maxLength": 100,
      "description": "Target price per unit if any"
    },
    "message": {
      "type": "string",
      "description": "Additional message or specific requirements"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "in_progress", "quoted", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the inquiry was submitted"
    }
  },
  "required": ["name", "email", "product_details"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
