{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Meeting Arrangements",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the attendee"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the attendee"
    },
    "attendance": {
      "type": "string",
      "enum": ["attending", "not_attending"],
      "description": "Whether the person will attend the meeting"
    },
    "dietary": {
      "type": "string",
      "maxLength": 200,
      "description": "Dietary requirements or preferences"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Any additional notes or comments"
    }
  },
  "required": ["name", "email", "attendance"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
