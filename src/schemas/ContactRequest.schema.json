{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Requests",
  "description": "Information from prospective customers interested in machinery.",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Customer name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "product_interest": {
      "type": "string",
      "enum": ["Double Folding Machine", "Sheet Metal Folder", "Metal Folding Machine", "Other"],
      "description": "Machine type of interest"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Customer message or inquiry"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Linked user account ID"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["owner"] },
    "update": { "allow": ["owner"] },
    "delete": { "allow": ["owner"] },
    "x-ownerColumn": "user_id"
  }
}
