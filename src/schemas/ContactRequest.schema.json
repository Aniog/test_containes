{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contact Requests",
  "type": "object",
  "description": "Inquiries from customers regarding machinery quotes and general questions.",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name of the contact person."
    },
    "company": {
      "type": "string",
      "description": "Company name."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address."
    },
    "phone": {
      "type": "string",
      "description": "Contact phone number."
    },
    "interest": {
      "type": "string",
      "enum": ["Double Folding Machine", "Sheet Metal Folder", "Service & Support", "Other"],
      "description": "Primary area of interest."
    },
    "message": {
      "type": "string",
      "description": "Detailed message or inquiry."
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
