{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fitness Plans",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the fitness plan"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of the fitness plan"
    },
    "goal": {
      "type": "string",
      "enum": ["增肌", "减脂", "塑形", "耐力", "力量", "综合"],
      "description": "Primary goal of the fitness plan"
    },
    "training_days": {
      "type": "array",
      "description": "List of training days in the plan",
      "items": {
        "type": "object",
        "description": "A single training day",
        "properties": {
          "day_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Name or label for this training day (e.g. 胸部训练日)"
          },
          "exercises": {
            "type": "array",
            "description": "List of exercises for this training day",
            "items": {
              "type": "object",
              "description": "A single exercise",
              "properties": {
                "exercise_name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100,
                  "description": "Name of the exercise"
                },
                "sets": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 20,
                  "description": "Number of sets"
                },
                "reps": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 100,
                  "description": "Number of repetitions per set"
                },
                "weight_kg": {
                  "type": ["number", "null"],
                  "minimum": 0,
                  "description": "Weight in kilograms (optional)"
                },
                "notes": {
                  "type": "string",
                  "maxLength": 200,
                  "description": "Optional notes for this exercise"
                }
              },
              "required": ["exercise_name", "sets", "reps"]
            }
          }
        },
        "required": ["day_name", "exercises"]
      }
    }
  },
  "required": ["name", "goal", "training_days"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
