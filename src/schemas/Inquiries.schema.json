{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user who submitted this inquiry",
      "x-foreignKey": "users.id"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the inquirer"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name of the inquirer"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone number of the inquirer"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "Inquiry message describing requirements"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}