{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Membership Tiers",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the membership tier (e.g., Basic, Premium, Unlimited)"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Description of what this membership tier includes"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Monthly price in USD"
    },
    "duration_months": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12,
      "description": "Duration of membership in months"
    },
    "classes_per_month": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of classes allowed per month (0 for unlimited)"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of features included in this tier"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this tier is currently available for purchase"
    },
    "sort_order": {
      "type": "integer",
      "minimum": 0,
      "description": "Display order for membership tiers"
    }
  },
  "required": ["name", "price", "duration_months", "classes_per_month"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["admin"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}