{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FavoriteGame",
  "type": "object",
  "properties": {
    "visitor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the visitor submitting their favorite games"
    },
    "visitor_email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the visitor — used to group all their game submissions together"
    },
    "game_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the favorite game"
    },
    "platform": {
      "type": "string",
      "enum": ["Steam", "Epic", "Nintendo Switch", "PlayStation", "Xbox", "PC", "Mobile", "Other"],
      "description": "Platform the game is played on"
    },
    "play_status": {
      "type": "string",
      "enum": ["Currently Playing", "Completed", "On Hold", "Dropped", "Plan to Play"],
      "description": "Current play status of the game"
    },
    "play_time_hours": {
      "type": "number",
      "minimum": 0,
      "description": "Total hours played on this game"
    },
    "reason": {
      "type": "string",
      "maxLength": 1000,
      "description": "Why the visitor likes this game"
    },
    "last_played_date": {
      "type": "string",
      "format": "date",
      "description": "The last date the visitor played this game"
    },
    "personal_rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Personal rating out of 5 stars"
    },
    "would_recommend": {
      "type": "boolean",
      "default": true,
      "description": "Whether the visitor would recommend this game to others"
    },
    "genre": {
      "type": "string",
      "enum": ["Action", "RPG", "Strategy", "Shooter", "Adventure", "Racing", "Sports", "Simulation", "Puzzle", "Horror", "Other"],
      "description": "Genre of the game"
    },
    "game_images": {
      "type": "array",
      "description": "Screenshots or images of the game uploaded by the visitor",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string", "minLength": 1 },
          "size": { "type": "integer", "minimum": 0 },
          "storageKey": { "type": "string" },
          "storage": { "type": "string" },
          "mimeType": { "type": "string" },
          "width": { "type": "integer", "minimum": 0 },
          "height": { "type": "integer", "minimum": 0 }
        },
        "x-upload": true,
        "x-fileType": "image",
        "x-allowedExtensions": [".jpg", ".jpeg", ".png", ".gif", ".webp"],
        "x-maxFileSize": 5242880,
        "x-mimeTypes": ["image/jpeg", "image/png", "image/gif", "image/webp"]
      }
    }
  },
  "required": ["visitor_name", "visitor_email", "game_name", "platform"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
