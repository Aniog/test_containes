{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Favorite Games",
  "type": "object",
  "properties": {
    "visitor_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the visitor submitting the form"
    },
    "visitor_email": {
      "type": "string",
      "format": "email",
      "description": "Optional email address of the visitor"
    },
    "game_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the favorite game"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "pc", "mobile", "other"],
      "description": "Platform the game is played on"
    },
    "genre": {
      "type": "string",
      "maxLength": 100,
      "description": "Genre of the game (e.g. RPG, FPS, Strategy)"
    },
    "play_time_hours": {
      "type": "number",
      "minimum": 0,
      "description": "Total hours played"
    },
    "last_play_date": {
      "type": "string",
      "format": "date",
      "description": "Date the game was last played"
    },
    "personal_rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Personal rating out of 10"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "Why the visitor likes this game"
    },
    "would_recommend": {
      "type": "boolean",
      "default": true,
      "description": "Whether the visitor would recommend this game to others"
    }
  },
  "required": ["visitor_name", "game_name", "platform", "reason"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
