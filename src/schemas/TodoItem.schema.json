{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todo Items",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "The title or content of the todo item"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the todo item has been completed"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium",
      "description": "Priority level of the todo item"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Optional due date for the todo item"
    },
    "category": {
      "type": "string",
      "maxLength": 50,
      "description": "Optional category or tag for the todo item"
    }
  },
  "required": ["title"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
