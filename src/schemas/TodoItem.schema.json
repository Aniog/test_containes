{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todo Item",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "The task description"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the task is completed"
    },
    "due_date": {
      "type": "string",
      "format": "date-time",
      "description": "Optional due date for the task"
    }
  },
  "required": ["title"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
