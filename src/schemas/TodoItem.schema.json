{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todo Items",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the todo item"
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "The todo item text content"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the todo item is completed"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the todo item was created"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the todo item was completed"
    }
  },
  "required": ["text"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}