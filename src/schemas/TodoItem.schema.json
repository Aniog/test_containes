{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todo Items",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "The description of the task"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the task has been completed"
    }
  },
  "required": ["title"],
  "additionalProperties": false
}
