{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contacts",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the contact"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the contact"
    },
    "company": {
      "type": "string",
      "maxLength": 100,
      "description": "Company or organization name (optional)"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Message submitted via the contact form"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
