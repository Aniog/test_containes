{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contacts",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 150,
      "description": "Full name of the person who submitted the form"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the contact"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Optional phone number"
    },
    "subject": {
      "type": "string",
      "maxLength": 200,
      "description": "Optional subject or topic of the message"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000,
      "description": "The message body submitted via the contact form"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
