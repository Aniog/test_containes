{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contacts",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Contact email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Contact phone number"
    },
    "first_name": {
      "type": "string",
      "maxLength": 100,
      "description": "First name of the contact"
    },
    "last_name": {
      "type": "string",
      "maxLength": 100,
      "description": "Last name of the contact"
    },
    "country_region_code": {
      "type": "string",
      "maxLength": 10,
      "description": "Country or region code (e.g. HK, JP, GB, DE)"
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "description": "City or location of the contact"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Contact website URL"
    },
    "facebook": {
      "type": "string",
      "format": "uri",
      "description": "Facebook profile URL"
    },
    "twitter": {
      "type": "string",
      "format": "uri",
      "description": "Twitter profile URL"
    },
    "instagram": {
      "type": "string",
      "format": "uri",
      "description": "Instagram profile URL"
    },
    "youtube": {
      "type": "string",
      "format": "uri",
      "description": "YouTube channel URL"
    }
  },
  "required": ["first_name", "last_name"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
