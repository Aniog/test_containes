{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "long_description": {
      "type": "string",
      "description": "Full product description"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["18K Gold Plated", "Sterling Silver", "Mixed"],
      "description": "Primary material"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Gold", "Silver"]
      },
      "description": "Available color variants"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average star rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is a bestseller"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "image_hover_url": {
      "type": "string",
      "format": "uri",
      "description": "Secondary hover image URL"
    },
    "materials_care": {
      "type": "string",
      "description": "Materials and care instructions"
    },
    "shipping_returns": {
      "type": "string",
      "description": "Shipping and returns policy"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
