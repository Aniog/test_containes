{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Product display name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "URL-friendly identifier"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "compare_at_price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Original price before discount, if applicable"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Short product description"
    },
    "materials": {
      "type": "string",
      "maxLength": 1000,
      "description": "Materials and care information"
    },
    "shipping": {
      "type": "string",
      "maxLength": 1000,
      "description": "Shipping and returns information"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average customer rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of customer reviews"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product tags for filtering"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Gold", "Silver"]
      },
      "description": "Available metal tone variants"
    },
    "image_query": {
      "type": "string",
      "maxLength": 500,
      "description": "Stock image search query for product imagery"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether this product appears in the bestsellers section"
    }
  },
  "required": ["name", "slug", "category", "price"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
