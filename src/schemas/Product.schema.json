{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "storageKey": { "type": "string" },
          "filename": { "type": "string" }
        }
      },
      "description": "Product images"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available variants (e.g., Gold, Silver)"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Mark as bestseller"
    },
    "material": {
      "type": "string",
      "description": "Material details"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
