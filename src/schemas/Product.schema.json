{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Product short description"
    },
    "materials": {
      "type": "string",
      "maxLength": 1000,
      "description": "Materials and care information"
    },
    "shipping_info": {
      "type": "string",
      "maxLength": 1000,
      "description": "Shipping and returns information"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["gold", "silver"]
      },
      "description": "Available color variants"
    },
    "image_query": {
      "type": "string",
      "description": "Stock image search query"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average customer rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is featured/bestseller"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    }
  },
  "required": ["id", "name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] }
  }
}