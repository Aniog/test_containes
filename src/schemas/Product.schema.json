{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Product description"
    },
    "materials_care": {
      "type": "string",
      "maxLength": 2000,
      "description": "Materials and care instructions"
    },
    "shipping_returns": {
      "type": "string",
      "maxLength": 2000,
      "description": "Shipping and returns information"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "compare_price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Compare-at price for sale display"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Product tags"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "image_hover_url": {
      "type": "string",
      "format": "uri",
      "description": "Hover product image URL"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average product rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "is_bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether this product is a bestseller"
    },
    "is_new": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a new arrival"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["gold", "silver"]
      },
      "description": "Available color variants"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}