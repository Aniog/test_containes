{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Product ID"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "URL slug"
    },
    "price": {
      "type": "integer",
      "minimum": 0,
      "description": "Price in USD cents"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["gold", "silver", "mixed"],
      "description": "Primary material"
    },
    "short_description": {
      "type": "string",
      "maxLength": 300,
      "description": "Short product description"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Full product description"
    },
    "materials_care": {
      "type": "string",
      "maxLength": 2000,
      "description": "Materials and care instructions"
    },
    "shipping_returns": {
      "type": "string",
      "maxLength": 2000,
      "description": "Shipping and returns policy"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average star rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "image_primary": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "image_secondary": {
      "type": "string",
      "format": "uri",
      "description": "Secondary product image URL"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available variant names"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] }
  }
}