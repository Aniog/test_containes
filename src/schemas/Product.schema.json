{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "compare_at_price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Original price before discount"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["18k-gold-plated", "sterling-silver", "gold-vermeil"],
      "description": "Primary material"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "description": "Product tags"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "hover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Secondary product image for hover"
    },
    "gallery_images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Gallery image URLs"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average star rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether product is in stock"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "price_adjustment": { "type": "number" },
          "in_stock": { "type": "boolean" }
        }
      },
      "description": "Product variants"
    },
    "details": {
      "type": "string",
      "description": "Detailed product description"
    },
    "materials_care": {
      "type": "string",
      "description": "Materials and care instructions"
    },
    "shipping_returns": {
      "type": "string",
      "description": "Shipping and returns policy"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    }
  },
  "required": ["id", "name", "slug", "price", "category", "description"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  },
  "additionalProperties": false
}
