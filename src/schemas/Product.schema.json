{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["18k-gold-plated", "sterling-silver", "gold-filled"],
      "description": "Primary material"
    },
    "tone": {
      "type": "string",
      "enum": ["gold", "silver", "both"],
      "description": "Available tone options"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "minItems": 1,
      "description": "Product image URLs"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average star rating"
    },
    "reviewCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is a bestseller"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "Whether product is active/visible"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    }
  },
  "required": ["id", "name", "slug", "price", "category", "material", "tone", "images", "isActive"],
  "additionalProperties": false
}