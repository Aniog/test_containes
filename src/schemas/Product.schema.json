{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "image_id": {
      "type": "string",
      "description": "Stock image identifier or query"
    },
    "details": {
      "type": "object",
      "properties": {
        "materials": { "type": "string" },
        "care": { "type": "string" }
      },
      "description": "Extra product details"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
