{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product display name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product handle"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "maxLength": 100,
      "description": "Primary material or finish"
    },
    "tone": {
      "type": "string",
      "enum": ["gold", "silver"],
      "description": "Metal tone variant"
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief product summary for cards"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Full product description"
    },
    "materialsCare": {
      "type": "string",
      "maxLength": 2000,
      "description": "Materials and care instructions"
    },
    "shippingReturns": {
      "type": "string",
      "maxLength": 2000,
      "description": "Shipping and returns policy text"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average customer rating"
    },
    "reviewsCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of customer reviews"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is a bestseller"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is featured"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
