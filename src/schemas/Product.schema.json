{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies"],
      "description": "Product category"
    },
    "image": {
      "type": "object",
      "properties": {
        "storageKey": { "type": "string" },
        "filename": { "type": "string" }
      },
      "x-upload": true,
      "x-fileType": "image",
      "description": "Main product image"
    },
    "secondaryImage": {
      "type": "object",
      "properties": {
        "storageKey": { "type": "string" },
        "filename": { "type": "string" }
      },
      "x-upload": true,
      "x-fileType": "image",
      "description": "Secondary image for hover effect"
    },
    "starRating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "default": 5,
      "description": "Average review rating"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is a bestseller"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
