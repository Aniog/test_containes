{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product display name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-safe product slug"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "long_description": {
      "type": "string",
      "description": "Detailed product description"
    },
    "materials_care": {
      "type": "string",
      "description": "Materials and care instructions"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies"],
      "description": "Product category"
    },
    "tone": {
      "type": "string",
      "enum": ["gold", "silver"],
      "description": "Metal tone"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average customer rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "hover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Hover state product image URL"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product tags"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Is this a bestseller"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] }
  }
}