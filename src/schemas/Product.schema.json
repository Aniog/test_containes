{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Short description"
    },
    "price": {
      "type": "number",
      "description": "Price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "image": {
      "type": "string",
      "format": "uri",
      "description": "Main image URL"
    },
    "hoverImage": {
      "type": "string",
      "format": "uri",
      "description": "Hover image URL"
    },
    "materials": {
      "type": "string",
      "description": "Material details"
    },
    "care": {
      "type": "string",
      "description": "Care instructions"
    }
  },
  "required": ["name", "price", "category", "image"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
