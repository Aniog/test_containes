{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the game/product"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "description": {
      "type": "string",
      "description": "Full description of the game"
    },
    "short_description": {
      "type": "string",
      "maxLength": 300,
      "description": "Short description for cards"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "screenshots": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "Screenshot image URLs"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Sale price in USD (if on sale)"
    },
    "on_sale": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is on sale"
    },
    "genre": {
      "type": "string",
      "enum": ["action", "rpg", "strategy", "sports", "simulation", "adventure", "puzzle", "shooter", "horror", "indie", "other"],
      "description": "Game genre"
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["pc", "steam", "epic", "nintendo", "playstation", "xbox"]
      },
      "description": "Platforms the game is available on"
    },
    "developer": {
      "type": "string",
      "maxLength": 100,
      "description": "Game developer"
    },
    "publisher": {
      "type": "string",
      "maxLength": 100,
      "description": "Game publisher"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Release date of the game"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average rating out of 5"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Number of reviews"
    },
    "stock": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "Available stock (license keys)"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is featured on the homepage"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the product is active/visible"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for the product"
    }
  },
  "required": ["title", "price", "genre"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
