{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["18k gold plated", "sterling silver", "mixed"],
      "description": "Primary material"
    },
    "tone": {
      "type": "string",
      "enum": ["gold", "silver"],
      "description": "Metal tone variant"
    },
    "short_description": {
      "type": "string",
      "maxLength": 300,
      "description": "Short product description for cards"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Full product description"
    },
    "care": {
      "type": "string",
      "maxLength": 1000,
      "description": "Materials and care instructions"
    },
    "shipping_returns": {
      "type": "string",
      "maxLength": 1000,
      "description": "Shipping and returns policy text"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average star rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "hover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Secondary hover image URL"
    },
    "gallery_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Gallery image URLs"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a bestseller"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
