{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product identifier"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["earrings", "necklaces", "huggies", "sets"],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Product description"
    },
    "materials": {
      "type": "string",
      "maxLength": 1000,
      "description": "Materials and care information"
    },
    "shipping_info": {
      "type": "string",
      "maxLength": 1000,
      "description": "Shipping and returns information"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average customer rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available variant names (e.g., Gold, Silver)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product tags for filtering"
    },
    "image_query": {
      "type": "string",
      "maxLength": 500,
      "description": "Search query for product imagery"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is featured on homepage"
    },
    "bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether product is a bestseller"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}