{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "description": "Product slug for URL"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies"],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "materials": {
      "type": "string",
      "description": "Materials and care information"
    },
    "shipping": {
      "type": "string",
      "description": "Shipping and returns information"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of product image descriptions for stock system"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product variants (e.g., Gold, Silver)"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether the product is a bestseller"
    }
  },
  "required": ["name", "price", "category", "slug"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
