{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "description": "Unique URL-friendly identifier"
    },
    "price": {
      "type": "number",
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "details": {
      "type": "string",
      "description": "Detailed product description"
    },
    "materials": {
      "type": "string",
      "description": "Materials and care information"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "storageKey": { "type": "string" },
          "alt": { "type": "string" }
        }
      },
      "description": "Product images"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available variants (e.g. Gold, Silver)"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "default": 5,
      "description": "Average star rating"
    },
    "reviewCount": {
      "type": "integer",
      "default": 0,
      "description": "Number of reviews"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Flag for bestseller status"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
