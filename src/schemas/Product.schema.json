{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Product name"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Price in USD"
    },
    "description": {
      "type": "string",
      "description": "Short product description"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "materials": {
      "type": "string",
      "description": "Material and care information"
    },
    "shipping_returns": {
      "type": "string",
      "description": "Shipping and returns policy"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "List of product image URLs"
    },
    "colors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available color variants (e.g. Gold Tone, Silver Tone)"
    },
    "is_bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Mark as bestseller"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "default": 5,
      "description": "Star rating"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": {
      "allow": ["*"]
    },
    "create": {
      "allow": ["admin"]
    },
    "update": {
      "allow": ["admin"]
    },
    "delete": {
      "allow": ["admin"]
    }
  }
}
