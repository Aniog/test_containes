{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Product price"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies"],
      "description": "Product category"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Product image URLs"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available tones (e.g. Gold, Silver)"
    },
    "details": {
      "type": "object",
      "properties": {
        "materials": { "type": "string" },
        "care": { "type": "string" },
        "shipping": { "type": "string" }
      },
      "description": "Accordion details"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
