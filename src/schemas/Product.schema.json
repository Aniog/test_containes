{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique product identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly product slug"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Product price in USD"
    },
    "original_price": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.01,
      "description": "Original price before discount"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["18K Gold Plated", "Sterling Silver", "Mixed"],
      "description": "Primary material"
    },
    "tone": {
      "type": "string",
      "enum": ["Gold", "Silver"],
      "description": "Metal tone"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Short product description"
    },
    "details": {
      "type": "string",
      "maxLength": 2000,
      "description": "Materials and care details"
    },
    "shipping_info": {
      "type": "string",
      "maxLength": 1000,
      "description": "Shipping and returns info"
    },
    "image_url": {
      "type": "string",
      "format": "uri",
      "description": "Primary product image URL"
    },
    "hover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Hover product image URL"
    },
    "gallery": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "Product gallery image URLs"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average customer rating"
    },
    "review_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of reviews"
    },
    "is_bestseller": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a bestseller"
    },
    "is_new": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a new arrival"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Product tags"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    }
  },
  "required": ["name", "slug", "price", "category", "image_url"],
  "additionalProperties": false,
  "x-security": {
    "read": { "allow": ["*"] }
  }
}
