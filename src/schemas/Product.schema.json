{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "slug": {
      "type": "string",
      "description": "Product slug for URL"
    },
    "price": {
      "type": "number",
      "description": "Product price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies", "Sets"],
      "description": "Product category"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Available variants (e.g. Gold, Silver)"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Flag for bestseller items"
    }
  },
  "required": ["name", "slug", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] }
  }
}
