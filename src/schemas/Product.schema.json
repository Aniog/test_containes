{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "description": {
      "type": "string",
      "description": "Product description"
    },
    "price": {
      "type": "number",
      "description": "Price in USD"
    },
    "category": {
      "type": "string",
      "enum": ["Earrings", "Necklaces", "Huggies"],
      "description": "Product category"
    },
    "material": {
      "type": "string",
      "enum": ["Gold Tone", "Silver Tone"],
      "description": "Material finish"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "storageKey": { "type": "string" },
          "filename": { "type": "string" }
        }
      },
      "description": "Product images"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "default": 4.5,
      "description": "Average rating"
    },
    "reviewCount": {
      "type": "integer",
      "default": 0,
      "description": "Number of reviews"
    },
    "isBestseller": {
      "type": "boolean",
      "default": false,
      "description": "Is this a bestseller?"
    }
  },
  "required": ["name", "price", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
