{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Leads",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the lead"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the lead"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the lead"
    },
    "company": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Company or organisation the lead belongs to"
    },
    "source": {
      "type": "string",
      "enum": ["Website", "Referral", "LinkedIn", "Cold Outreach", "Trade Show", "Other", ""],
      "description": "Channel through which the lead was acquired"
    },
    "status": {
      "type": "string",
      "enum": ["New", "Contacted", "Qualified", "Proposal", "Won", "Lost"],
      "default": "New",
      "description": "Current stage of the lead in the sales pipeline"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Free-text notes about the lead"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the user (visitor) who submitted the lead capture form",
      "x-foreignKey": "users.id"
    }
  },
  "required": ["name", "email", "company", "status"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
