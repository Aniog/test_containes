{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Games",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Game title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "platform": {
      "type": "string",
      "enum": ["Steam", "Epic", "Nintendo", "PlayStation", "Xbox", "Multi-Platform"],
      "description": "Gaming platform"
    },
    "genre": {
      "type": "string",
      "maxLength": 100,
      "description": "Game genre"
    },
    "description": {
      "type": "string",
      "description": "Game description"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Cover image URL"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Sale price in USD (if on sale)"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Discount percentage"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Game rating out of 5"
    },
    "developer": {
      "type": "string",
      "maxLength": 100,
      "description": "Game developer"
    },
    "publisher": {
      "type": "string",
      "maxLength": 100,
      "description": "Game publisher"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Release date"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Game tags"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the game is featured"
    },
    "in_stock": {
      "type": "boolean",
      "default": true,
      "description": "Whether the game is available for purchase"
    }
  },
  "required": ["title", "platform", "price", "description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
