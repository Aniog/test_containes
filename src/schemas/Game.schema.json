{
  "name": "Game",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Game title"
    },
    "description": {
      "type": "string",
      "description": "Game description"
    },
    "price": {
      "type": "number",
      "description": "Current price in USD"
    },
    "original_price": {
      "type": "number",
      "description": "Original price before discount"
    },
    "discount_percentage": {
      "type": "integer",
      "description": "Discount percentage (0-100)"
    },
    "platform": {
      "type": "string",
      "enum": ["Steam", "Epic", "PlayStation 5", "PlayStation 4", "Xbox Series", "Xbox One", "Nintendo Switch", "Nintendo Wii U", "Nintendo 3DS", "PlayStation Vita", "PSP", "Game Boy Advance", "Nintendo DS"],
      "description": "Gaming platform"
    },
    "genre": {
      "type": "string",
      "description": "Game genre"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Game release date"
    },
    "rating": {
      "type": "number",
      "description": "Game rating (0-10)"
    },
    "image_url": {
      "type": "string",
      "description": "Game cover image URL"
    },
    "trailer_url": {
      "type": "string",
      "description": "Game trailer video URL"
    },
    "is_featured": {
      "type": "boolean",
      "description": "Whether the game is featured on homepage"
    },
    "is_on_sale": {
      "type": "boolean",
      "description": "Whether the game is currently on sale"
    },
    "stock_quantity": {
      "type": "integer",
      "description": "Available stock quantity"
    }
  },
  "required": [
    "title",
    "description",
    "price",
    "platform",
    "genre"
  ]
}