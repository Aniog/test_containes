{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Games",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Game title"
    },
    "slug": {
      "type": "string",
      "maxLength": 200,
      "description": "URL-friendly slug"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Game description"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Game cover image URL"
    },
    "genre": {
      "type": "string",
      "enum": ["action", "rpg", "strategy", "sports", "adventure", "simulation", "horror", "puzzle", "shooter", "fighting"],
      "description": "Game genre"
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["steam", "epic", "nintendo", "playstation", "xbox"]
      },
      "description": "Available platforms"
    },
    "price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Sale price in USD (if on sale)"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Discount percentage"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Average rating out of 5"
    },
    "release_date": {
      "type": "string",
      "format": "date",
      "description": "Game release date"
    },
    "developer": {
      "type": "string",
      "maxLength": 100,
      "description": "Game developer"
    },
    "publisher": {
      "type": "string",
      "maxLength": 100,
      "description": "Game publisher"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this game is featured in the store"
    },
    "is_on_sale": {
      "type": "boolean",
      "default": false,
      "description": "Whether this game is currently on sale"
    },
    "stock": {
      "type": "integer",
      "minimum": 0,
      "description": "Available stock (keys)"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Game tags"
    }
  },
  "required": ["title", "price", "genre"],
  "x-security": {
    "create": { "allow": [] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
