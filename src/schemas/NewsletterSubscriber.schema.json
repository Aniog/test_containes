{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Subscribers",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "订阅者邮箱"
    },
    "name": {
      "type": "string",
      "maxLength": 100,
      "description": "订阅者姓名（可选）"
    },
    "status": {
      "type": "string",
      "enum": ["active", "unsubscribed"],
      "default": "active",
      "description": "订阅状态：active=已订阅, unsubscribed=已退订"
    },
    "source": {
      "type": "string",
      "enum": ["homepage", "blog", "popup", "other"],
      "default": "homepage",
      "description": "订阅来源页面"
    }
  },
  "required": ["email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
