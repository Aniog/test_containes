{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Subscribers",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Subscriber email address"
    },
    "subscribed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when the subscriber signed up"
    },
    "source": {
      "type": "string",
      "maxLength": 100,
      "description": "Where the subscription originated, e.g. homepage, footer"
    }
  },
  "required": ["email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
