{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Subscribers",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Subscriber's email address"
    },
    "status": {
      "type": "string",
      "enum": ["active", "unsubscribed"],
      "default": "active",
      "description": "Subscription status"
    }
  },
  "required": ["email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
