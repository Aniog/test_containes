{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Subscribers",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "description": "Subscriber's email address"
    },
    "subscribed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the subscriber signed up"
    },
    "source": {
      "type": "string",
      "maxLength": 100,
      "description": "Where on the site the signup originated, e.g. homepage_footer"
    }
  },
  "required": ["email"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
