{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Posts",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly slug"
    },
    "excerpt": {
      "type": "string",
      "description": "Short summary for preview"
    },
    "content": {
      "type": "string",
      "description": "Full HTML content"
    },
    "cover_image": {
      "type": "object",
      "properties": {
        "storageKey": { "type": "string" }
      },
      "x-upload": true,
      "x-fileType": "image",
      "description": "Main image for the post"
    },
    "author": {
      "type": "string",
      "description": "Author name"
    },
    "category": {
      "type": "string",
      "enum": ["Sourcing Guide", "Quality Control", "Shipping & Logistics", "Market Trends"],
      "description": "Post category"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date"
    }
  },
  "required": ["title", "slug", "content"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
