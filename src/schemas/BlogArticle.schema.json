{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "maxLength": 300,
      "description": "URL-friendly slug"
    },
    "excerpt": {
      "type": "string",
      "maxLength": 500,
      "description": "Short excerpt or summary"
    },
    "content": {
      "type": "string",
      "description": "Full article content (HTML or markdown)"
    },
    "category": {
      "type": "string",
      "enum": ["News", "Review", "Guide", "Feature", "Deals", "Esports"],
      "description": "Article category"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author name"
    },
    "cover_image": {
      "type": "object",
      "description": "Article cover image",
      "properties": {
        "filename": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "minimum": 0 },
        "storageKey": { "type": "string" },
        "storage": { "type": "string" },
        "mimeType": { "type": "string" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      },
      "x-upload": true,
      "x-fileType": "image",
      "x-allowedExtensions": [".jpg", ".jpeg", ".png", ".webp"],
      "x-maxFileSize": 5242880,
      "x-mimeTypes": ["image/jpeg", "image/png", "image/webp"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Article tags"
    },
    "platform_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Steam", "Epic", "Nintendo", "PlayStation", "Xbox", "PC", "Mobile"]
      },
      "description": "Related gaming platforms"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Publication date and time"
    },
    "is_published": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is published"
    },
    "is_featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether the article is featured"
    },
    "read_time_minutes": {
      "type": "integer",
      "minimum": 1,
      "description": "Estimated read time in minutes"
    },
    "views": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "View count"
    }
  },
  "required": ["title", "category"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
