{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blog Articles",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Article headline"
    },
    "excerpt": {
      "type": "string",
      "maxLength": 500,
      "description": "Short summary shown in card previews"
    },
    "content": {
      "type": "string",
      "description": "Full article body text"
    },
    "category": {
      "type": "string",
      "enum": ["news", "blog", "article", "review", "guide"],
      "description": "Content category"
    },
    "author": {
      "type": "string",
      "maxLength": 100,
      "description": "Author display name"
    },
    "published_at": {
      "type": "string",
      "format": "date",
      "description": "Publication date"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of topic tags"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox", "all"],
      "description": "Related gaming platform, or all for platform-agnostic articles"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether this article is pinned as featured"
    }
  },
  "required": ["title", "category", "published_at"],
  "x-security": {
    "read": { "allow": ["*"] }
  }
}
