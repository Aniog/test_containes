{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the person making the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Business email address"
    },
    "company": {
      "type": "string",
      "maxLength": 150,
      "description": "Company or workshop name"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Contact phone number"
    },
    "productInterest": {
      "type": "string",
      "enum": [
        "double-folding-machine",
        "double-folder",
        "sheet-metal-folder",
        "sheet-metal-folding-machine",
        "metal-folder",
        "metal-folder-machine",
        "metal-folding-machine",
        "custom-solution"
      ],
      "description": "Product the visitor is interested in"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "description": "Inquiry message describing requirements"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
