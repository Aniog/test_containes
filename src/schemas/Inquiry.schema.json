{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the contact person"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "phone": {
      "type": "string",
      "description": "Phone number/WhatsApp"
    },
    "product_description": {
      "type": "string",
      "description": "What products are you looking to source?"
    },
    "estimated_order_volume": {
      "type": "string",
      "description": "Estimated order quantity or budget"
    },
    "services_needed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Supplier Sourcing",
          "Factory Audit",
          "Sample Consolidation",
          "Quality Inspection",
          "Production Monitoring",
          "Shipping & Logistics"
        ]
      },
      "description": "Services the client is interested in"
    },
    "message": {
      "type": "string",
      "description": "Additional details or questions"
    },
    "status": {
      "type": "string",
      "enum": ["new", "reviewed", "contacted", "qualified", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Linked user ID if authenticated"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Submission time"
    }
  },
  "required": ["name", "email", "product_description"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin", "owner"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] },
    "x-ownerColumn": "user_id"
  }
}
