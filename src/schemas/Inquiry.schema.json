{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiries",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Linked user ID"
    },
    "name": {
      "type": "string",
      "description": "Sender name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Sender email"
    },
    "product_id": {
      "type": "string",
      "description": "Interested product"
    },
    "message": {
      "type": "string",
      "description": "Inquiry message"
    },
    "status": {
      "type": "string",
      "enum": ["new", "contacted", "closed"],
      "default": "new",
      "description": "Status of the inquiry"
    }
  },
  "required": ["email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
