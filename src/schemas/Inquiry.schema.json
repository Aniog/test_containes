{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiries",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Customer name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Customer email"
    },
    "product_id": {
      "type": "string",
      "description": "Related product ID (optional)"
    },
    "message": {
      "type": "string",
      "description": "Inquiry message"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
