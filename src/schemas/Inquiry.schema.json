{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sourcing Inquiries",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the inquiry"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the inquirer"
    },
    "company": {
      "type": "string",
      "maxLength": 200,
      "description": "Company name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address for communication"
    },
    "phone": {
      "type": "string",
      "maxLength": 50,
      "description": "Phone or WhatsApp number"
    },
    "country": {
      "type": "string",
      "maxLength": 100,
      "description": "Country of the buyer"
    },
    "product_category": {
      "type": "string",
      "maxLength": 100,
      "description": "Category of product to source"
    },
    "order_volume": {
      "type": "string",
      "maxLength": 100,
      "description": "Estimated order volume or budget"
    },
    "product_details": {
      "type": "string",
      "minLength": 1,
      "description": "Detailed product description and requirements"
    },
    "timeline": {
      "type": "string",
      "maxLength": 200,
      "description": "Expected timeline for the project"
    },
    "status": {
      "type": "string",
      "enum": ["new", "in_review", "quoted", "closed"],
      "default": "new",
      "description": "Current status of the inquiry"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the inquiry was submitted"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the inquiry was last updated"
    }
  },
  "required": ["name", "email", "product_details"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] },
    "update": { "allow": ["admin"] },
    "delete": { "allow": ["admin"] }
  }
}
