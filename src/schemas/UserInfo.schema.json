{
  "name": "User Info",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "User's full name"
    },
    "email": {
      "type": "string",
      "description": "User's email address"
    },
    "phone": {
      "type": "string",
      "description": "User's phone number"
    },
    "company": {
      "type": "string",
      "description": "User's company or organization"
    },
    "job_title": {
      "type": "string",
      "description": "User's job title or position"
    },
    "interest_in_ai": {
      "type": "string",
      "description": "User's level of interest in AI solutions",
      "enum": ["Beginner", "Intermediate", "Advanced", "Expert"]
    },
    "use_case": {
      "type": "string",
      "description": "Primary use case or application area"
    },
    "budget_range": {
      "type": "string",
      "description": "Budget range for AI solutions",
      "enum": ["Under $1,000", "$1,000 - $5,000", "$5,000 - $10,000", "$10,000 - $50,000", "Over $50,000"]
    },
    "newsletter_subscription": {
      "type": "boolean",
      "description": "Whether user wants to subscribe to newsletter"
    }
  },
  "required": [
    "full_name",
    "email",
    "interest_in_ai"
  ]
}