{
  "name": "User",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "description": "User's first name"
    },
    "last_name": {
      "type": "string",
      "description": "User's last name"
    },
    "email": {
      "type": "string",
      "description": "User's email address"
    },
    "phone": {
      "type": "string",
      "description": "User's phone number"
    },
    "date_of_birth": {
      "type": "string",
      "description": "User's date of birth in YYYY-MM-DD format"
    },
    "address": {
      "type": "object",
      "properties": {
        "street": {
          "type": "string",
          "description": "Street address"
        },
        "city": {
          "type": "string",
          "description": "City"
        },
        "state": {
          "type": "string",
          "description": "State or province"
        },
        "zip_code": {
          "type": "string",
          "description": "ZIP or postal code"
        },
        "country": {
          "type": "string",
          "description": "Country"
        }
      },
      "required": ["street", "city", "state", "zip_code", "country"]
    },
    "preferences": {
      "type": "object",
      "properties": {
        "newsletter_subscription": {
          "type": "boolean",
          "description": "Whether user wants to receive newsletters"
        },
        "marketing_emails": {
          "type": "boolean",
          "description": "Whether user wants to receive marketing emails"
        },
        "preferred_language": {
          "type": "string",
          "description": "User's preferred language"
        }
      }
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "User's interests and hobbies"
    },
    "occupation": {
      "type": "string",
      "description": "User's occupation or job title"
    },
    "company": {
      "type": "string",
      "description": "User's company name"
    }
  },
  "required": [
    "first_name",
    "last_name",
    "email"
  ]
}