{
  "name": "User",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "User's full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User's email address"
    },
    "phone": {
      "type": "string",
      "description": "User's phone number"
    },
    "company": {
      "type": "string",
      "description": "User's company or organization"
    },
    "job_title": {
      "type": "string",
      "description": "User's job title or position"
    },
    "interest_in_ai": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"],
      "description": "User's level of interest/experience in AI"
    },
    "use_case": {
      "type": "string",
      "description": "How the user plans to use AI solutions"
    },
    "newsletter_subscription": {
      "type": "boolean",
      "description": "Whether user wants to subscribe to newsletter",
      "default": false
    }
  },
  "required": [
    "full_name",
    "email",
    "interest_in_ai"
  ]
}