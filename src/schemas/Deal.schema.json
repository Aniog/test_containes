{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deals",
  "type": "object",
  "properties": {
    "game_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the game"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Gaming platform offering the deal"
    },
    "original_price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Sale price in USD"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Discount percentage"
    },
    "cover_image_url": {
      "type": "string",
      "format": "uri",
      "description": "Game cover image URL"
    },
    "store_url": {
      "type": "string",
      "format": "uri",
      "description": "Link to the store page"
    },
    "genre": {
      "type": "string",
      "maxLength": 100,
      "description": "Game genre"
    },
    "deal_ends_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the deal expires"
    },
    "is_free": {
      "type": "boolean",
      "default": false,
      "description": "Whether the game is free (e.g. Epic free game)"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the deal is currently active"
    }
  },
  "required": ["game_title", "platform", "original_price", "sale_price", "discount_percent"],
  "x-security": {
    "create": { "allow": [] },
    "read": { "allow": ["*"] },
    "update": { "allow": [] },
    "delete": { "allow": [] }
  }
}
