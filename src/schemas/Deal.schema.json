{
  "name": "Deal",
  "type": "object",
  "properties": {
    "game_title": {
      "type": "string",
      "description": "Game title on sale"
    },
    "platform": {
      "type": "string",
      "enum": ["Steam", "Epic", "Nintendo Switch", "PlayStation", "Xbox"],
      "description": "Gaming platform"
    },
    "original_price": {
      "type": "number",
      "description": "Original price"
    },
    "sale_price": {
      "type": "number",
      "description": "Sale price"
    },
    "discount_percentage": {
      "type": "integer",
      "description": "Discount percentage (0-100)"
    },
    "deal_type": {
      "type": "string",
      "enum": ["Daily Deal", "Weekly Sale", "Seasonal Sale", "Flash Sale", "Bundle"],
      "description": "Type of deal"
    },
    "start_date": {
      "type": "string",
      "format": "date-time",
      "description": "Deal start date"
    },
    "end_date": {
      "type": "string",
      "format": "date-time",
      "description": "Deal end date"
    },
    "image_url": {
      "type": "string",
      "description": "Game image URL"
    },
    "store_url": {
      "type": "string",
      "description": "Direct link to store page"
    },
    "is_active": {
      "type": "boolean",
      "description": "Whether the deal is currently active"
    },
    "is_featured": {
      "type": "boolean",
      "description": "Whether the deal is featured"
    },
    "genre": {
      "type": "string",
      "description": "Game genre"
    },
    "rating": {
      "type": "number",
      "description": "Game rating (0-10)"
    }
  },
  "required": [
    "game_title",
    "platform",
    "original_price",
    "sale_price",
    "discount_percentage",
    "deal_type",
    "start_date",
    "end_date",
    "image_url"
  ]
}