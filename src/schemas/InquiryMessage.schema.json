{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiry Messages",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "format": "uuid",
      "x-foreignKey": "users.id",
      "description": "Linked user ID"
    },
    "name": {
      "type": "string",
      "description": "Sender name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Sender email"
    },
    "phone": {
      "type": "string",
      "description": "Sender phone number"
    },
    "company": {
      "type": "string",
      "description": "Sender company name"
    },
    "message": {
      "type": "string",
      "description": "Inquiry message"
    },
    "product_id": {
      "type": "integer",
      "description": "Interested product ID (optional)"
    }
  },
  "required": ["name", "email", "message"],
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["admin"] }
  }
}
