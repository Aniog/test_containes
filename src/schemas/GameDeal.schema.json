{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Deals",
  "type": "object",
  "properties": {
    "game_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the game"
    },
    "platform": {
      "type": "string",
      "enum": ["steam", "epic", "nintendo", "playstation", "xbox"],
      "description": "Store platform offering the deal"
    },
    "genre": {
      "type": "string",
      "maxLength": 60,
      "description": "Game genre label"
    },
    "original_price": {
      "type": "number",
      "minimum": 0,
      "description": "Original price in USD"
    },
    "sale_price": {
      "type": "number",
      "minimum": 0,
      "description": "Discounted sale price in USD"
    },
    "discount_percent": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Discount percentage"
    },
    "sale_end_date": {
      "type": "string",
      "format": "date",
      "description": "Date when the sale ends"
    },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "description": "Community rating out of 5"
    },
    "is_free": {
      "type": "boolean",
      "default": false,
      "description": "Whether the game is currently free to claim"
    }
  },
  "required": ["game_title", "platform", "original_price", "sale_price", "discount_percent"],
  "x-security": {
    "read": { "allow": ["*"] }
  }
}
