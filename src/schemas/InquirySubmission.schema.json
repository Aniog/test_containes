{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Inquiry Submissions",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "description": "Full name of the person submitting the inquiry"
    },
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Contact email address"
    },
    "phone": {
      "type": "string",
      "maxLength": 40,
      "description": "Contact phone number"
    },
    "company": {
      "type": "string",
      "maxLength": 160,
      "description": "Company or organization name"
    },
    "product_interest": {
      "type": "string",
      "maxLength": 120,
      "description": "The machine type the customer is interested in"
    },
    "message": {
      "type": "string",
      "maxLength": 2000,
      "description": "Free-text inquiry message"
    }
  },
  "required": ["name", "email", "message"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
