{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Weather Records",
  "type": "object",
  "properties": {
    "city": {
      "type": "string",
      "maxLength": 100,
      "description": "Name of the city"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the weather observation"
    },
    "temp_high": {
      "type": "number",
      "description": "Daily high temperature in Celsius"
    },
    "temp_low": {
      "type": "number",
      "description": "Daily low temperature in Celsius"
    },
    "humidity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Relative humidity percentage"
    },
    "wind_speed": {
      "type": "number",
      "minimum": 0,
      "description": "Wind speed in km/h"
    },
    "condition": {
      "type": "string",
      "enum": ["Sunny", "Partly Cloudy", "Cloudy", "Rainy", "Stormy", "Snowy", "Foggy", "Windy"],
      "description": "General weather condition"
    },
    "precipitation": {
      "type": "number",
      "minimum": 0,
      "description": "Precipitation in mm"
    },
    "uv_index": {
      "type": "integer",
      "minimum": 0,
      "maximum": 11,
      "description": "UV index (0-11)"
    }
  },
  "required": ["city", "date", "temp_high", "temp_low", "condition"],
  "x-security": {
    "read": { "allow": ["*"] },
    "create": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
