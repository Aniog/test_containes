{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fitness Plans",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the fitness plan"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief description of the fitness plan"
    }
  },
  "required": ["name"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
