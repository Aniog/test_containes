{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fitness Plans",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "健身计划名称"
    },
    "fitness_type": {
      "type": "string",
      "enum": ["strength", "cardio", "flexibility", "hiit", "yoga", "crossfit"],
      "description": "选择健身类型"
    },
    "training_days": {
      "type": "array",
      "description": "训练日列表",
      "items": {
        "type": "object",
        "properties": {
          "training_date": {
            "type": "string",
            "format": "date",
            "description": "选择训练日期"
          },
          "day_type": {
            "type": "string",
            "enum": ["Training", "Rest", "Recovery"],
            "description": "选择训练日类型"
          },
          "scheduled_time": {
            "type": "string",
            "enum": ["Morning", "Afternoon", "Evening"],
            "description": "选择计划训练时间"
          },
          "exercises": {
            "type": "array",
            "description": "该训练日的动作列表",
            "items": {
              "type": "object",
              "properties": {
                "exercise_date": {
                  "type": "string",
                  "format": "date",
                  "description": "选择该动作的训练日期"
                },
                "exercise_type": {
                  "type": "string",
                  "enum": ["Strength", "Cardio", "Mobility", "Stretching"],
                  "description": "选择动作类型"
                },
                "exercise_name": {
                  "type": "string",
                  "enum": ["Push-up", "Squat", "Plank", "Burpee", "Running"],
                  "description": "选择动作名称"
                },
                "intensity": {
                  "type": "string",
                  "enum": ["Low", "Medium", "High"],
                  "description": "选择训练强度"
                },
                "sets": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "组数"
                },
                "reps": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "每组重复次数"
                }
              },
              "required": ["exercise_date", "exercise_type", "exercise_name", "intensity"]
            }
          }
        },
        "required": ["training_date", "day_type", "scheduled_time", "exercises"]
      }
    }
  },
  "required": ["name", "fitness_type", "training_days"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
