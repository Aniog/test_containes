{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fitness Plans",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the fitness plan"
    },
    "fitness_type": {
      "type": "string",
      "enum": ["strength", "cardio", "flexibility", "hiit", "yoga", "crossfit"],
      "description": "Type of fitness training"
    },
    "training_days": {
      "type": "array",
      "description": "List of training days in the plan",
      "items": {
        "type": "object",
        "properties": {
          "training_date": {
            "type": "string",
            "format": "date",
            "description": "Training date"
          },
          "training_time": {
            "type": "string",
            "description": "Training time (HH:MM)"
          },
          "day_type": {
            "type": "string",
            "enum": ["Training", "Rest", "Recovery"],
            "description": "Type of training day"
          },
          "focus_area": {
            "type": "string",
            "enum": ["Full Body", "Upper Body", "Lower Body", "Core", "Cardio"],
            "description": "Main focus area"
          },
          "exercises": {
            "type": "array",
            "description": "Exercises for this training day",
            "items": {
              "type": "object",
              "properties": {
                "exercise_name": { "type": "string", "description": "Name of the exercise" },
                "sets": { "type": "integer", "description": "Number of sets" },
                "reps": { "type": "integer", "description": "Reps per set" },
                "intensity": {
                  "type": "string",
                  "enum": ["Low", "Medium", "High"],
                  "description": "Exercise intensity"
                }
              },
              "required": ["exercise_name", "sets", "reps"]
            }
          }
        },
        "required": ["training_date", "day_type", "focus_area", "exercises"]
      }
    }
  },
  "required": ["name", "fitness_type", "training_days"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
