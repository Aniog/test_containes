{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Todo Items",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "The title or content of the todo task"
    },
    "completed": {
      "type": "boolean",
      "default": false,
      "description": "Whether the task is completed"
    }
  },
  "required": [
    "title"
  ],
  "additionalProperties": false,
  "x-security": {
    "create": {
      "allow": [
        "*"
      ]
    },
    "read": {
      "allow": [
        "*"
      ]
    },
    "update": {
      "allow": [
        "*"
      ]
    },
    "delete": {
      "allow": [
        "*"
      ]
    }
  }
}