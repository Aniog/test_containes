{
  "name": "Tulip Flower",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the tulip variety"
    },
    "color": {
      "type": "string",
      "description": "Primary color of the tulip"
    },
    "bloom_time": {
      "type": "string",
      "enum": ["Early Spring", "Mid Spring", "Late Spring", "Early Summer"],
      "description": "When the tulip typically blooms"
    },
    "height": {
      "type": "number",
      "description": "Height of the tulip in centimeters"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the tulip flower"
    },
    "image_url": {
      "type": "string",
      "description": "URL or path to the tulip image"
    },
    "planting_depth": {
      "type": "number",
      "description": "Recommended planting depth in centimeters"
    },
    "is_perennial": {
      "type": "boolean",
      "description": "Whether the tulip is perennial or annual"
    }
  },
  "required": [
    "name",
    "color",
    "bloom_time",
    "height",
    "description"
  ]
}