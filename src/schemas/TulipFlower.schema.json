{
  "name": "TulipFlower",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the tulip variety"
    },
    "color": {
      "type": "string",
      "description": "Primary color of the tulip"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the tulip flower"
    },
    "bloom_season": {
      "type": "string",
      "enum": ["early_spring", "mid_spring", "late_spring"],
      "description": "When the tulip typically blooms"
    },
    "height": {
      "type": "number",
      "description": "Height of the tulip in centimeters"
    },
    "image_url": {
      "type": "string",
      "description": "URL to the tulip flower image"
    },
    "is_featured": {
      "type": "boolean",
      "description": "Whether this tulip should be featured prominently",
      "default": false
    }
  },
  "required": [
    "name",
    "color",
    "description"
  ]
}