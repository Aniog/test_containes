{
  "name": "TulipFlower",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name or variety of the tulip flower"
    },
    "color": {
      "type": "string",
      "description": "Primary color of the tulip flower"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the tulip flower"
    },
    "bloom_time": {
      "type": "string",
      "enum": ["Early Spring", "Mid Spring", "Late Spring", "Early Summer"],
      "description": "When the tulip typically blooms"
    },
    "height": {
      "type": "number",
      "description": "Height of the tulip in inches"
    },
    "image_url": {
      "type": "string",
      "description": "URL or path to the tulip flower image"
    },
    "planting_depth": {
      "type": "number",
      "description": "Recommended planting depth in inches"
    },
    "sun_requirement": {
      "type": "string",
      "enum": ["Full Sun", "Partial Sun", "Partial Shade"],
      "description": "Sunlight requirements for optimal growth"
    },
    "is_featured": {
      "type": "boolean",
      "description": "Whether this tulip should be featured prominently"
    }
  },
  "required": [
    "name",
    "color",
    "description",
    "bloom_time",
    "height"
  ]
}