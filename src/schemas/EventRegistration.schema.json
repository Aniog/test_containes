{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event Registrations",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "integer",
      "description": "Reference to the event"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the registering user",
      "x-foreignKey": "users.id"
    },
    "member_name": {
      "type": "string",
      "maxLength": 100,
      "description": "Name of the registrant"
    },
    "member_email": {
      "type": "string",
      "format": "email",
      "description": "Email of the registrant"
    },
    "member_phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone of the registrant"
    },
    "payment_status": {
      "type": "string",
      "enum": ["pending", "paid", "waived", "refunded"],
      "default": "pending",
      "description": "Payment status for paid events"
    },
    "payment_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Amount paid (HKD)"
    },
    "payment_method": {
      "type": "string",
      "enum": ["fps", "bank_transfer", "cash", "other"],
      "description": "Payment method used"
    },
    "payment_reference": {
      "type": "string",
      "maxLength": 100,
      "description": "Payment reference number"
    },
    "payment_proof_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of payment proof screenshot"
    },
    "attendance_status": {
      "type": "string",
      "enum": ["registered", "attended", "absent", "cancelled"],
      "default": "registered",
      "description": "Attendance status"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Additional notes from registrant"
    }
  },
  "required": ["event_id", "user_id", "member_name", "member_email"],
  "x-security": {
    "x-ownerColumn": "user_id",
    "create": { "allow": ["user"] },
    "read": { "allow": ["owner", "user"] },
    "update": { "allow": ["owner"] },
    "delete": { "allow": ["owner"] }
  }
}
