{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Products",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "Unique product ID" },
    "name": { "type": "string", "description": "Product name" },
    "price": { "type": "number", "description": "Price in USD" },
    "category": { "type": "string", "description": "Product category (e.g. Earrings, Necklaces, Huggies)" },
    "description": { "type": "string", "description": "Product description" },
    "image_prompt": { "type": "string", "description": "Prompt or query for dynamic stock image generation" }
  },
  "required": ["id", "name", "price", "category", "description", "image_prompt"],
  "additionalProperties": false
}