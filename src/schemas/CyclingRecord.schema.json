{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Your Cycling Record (May)",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Full name of the participant"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the participant"
    },
    "phone": {
      "type": "string",
      "maxLength": 30,
      "description": "Phone number of the participant"
    },
    "age": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120,
      "description": "Age of the participant"
    },
    "sex": {
      "type": "string",
      "enum": ["Male", "Female", "Other", "Prefer not to say"],
      "description": "Gender of the participant"
    },
    "records": {
      "type": "array",
      "description": "List of cycling records for May",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "Date of the cycling session (must be in May)"
          },
          "start_at": {
            "type": "string",
            "format": "time",
            "description": "Start time of the cycling session"
          },
          "end_at": {
            "type": "string",
            "format": "time",
            "description": "End time of the cycling session"
          },
          "location": {
            "type": "string",
            "maxLength": 200,
            "description": "Location of the cycling session"
          },
          "distance_km": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "Distance cycled in kilometers (1 to 10)"
          }
        },
        "required": ["date", "start_at", "end_at", "location", "distance_km"]
      }
    }
  },
  "required": ["name", "email", "records"],
  "x-security": {
    "create": { "allow": ["*"] }
  }
}
