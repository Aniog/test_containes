{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Newsletter Signups",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "format": "email",
      "maxLength": 160,
      "description": "Email address submitted for Velmora newsletter offers"
    },
    "source": {
      "type": "string",
      "maxLength": 80,
      "description": "Signup placement or campaign source"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the newsletter signup was submitted"
    }
  },
  "required": ["email", "source", "createdAt"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*", "guest", "user"] }
  }
}
