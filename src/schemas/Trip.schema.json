{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trips",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Name of the trip"
    },
    "destination": {
      "type": "string",
      "maxLength": 200,
      "description": "Destination of the trip"
    }
  },
  "required": ["name"],
  "additionalProperties": false,
  "x-security": {
    "create": { "allow": ["*"] },
    "read": { "allow": ["*"] },
    "update": { "allow": ["*"] },
    "delete": { "allow": ["*"] }
  }
}
